---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const apiKey = 'ak_live_eQDEkmlEmMg7LxNcuE6WYLAXeQDEkmlE';
  const apiUrl = 'https://api.cas-per.it/api/public/v1/annunci?limit=100';
  
  try {
    const res = await fetch(apiUrl, {
      headers: {
        'X-API-Key': apiKey,
        'Accept': 'application/json'
      }
    });

    if (!res.ok) {
      throw new Error(`getStaticPaths failed: ${res.status}`);
    }

    const json = await res.json();
    const items = json.data || [];
    
    return items.map((item: any) => ({
      params: { slug: item.slug },
      props: { item }
    }));
  } catch (err) {
    console.error('Error generating static paths for necrologi:', err);
    return [];
  }
}

const { slug } = Astro.params;
const { item } = Astro.props;

if (!item) {
  return Astro.redirect('/404');
}

const defunto = item.defunto || {};
const annuncio = item.annuncio || {};
const funerale = item.funerale || {};
const rosario = item.rosario || {};
const sepoltura = item.sepoltura || {};
const luogoRiposo = item.luogo_riposo || {};
const streaming = item.streaming || {};
const nomeCompleto = item.nominativo || `${defunto.nome || ''} ${defunto.cognome || ''}`.trim();
const haFoto = !!defunto.foto_url;

function formatMorte(dateStr: string) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    const year = parts[0];
    const monthIndex = parseInt(parts[1], 10) - 1;
    const day = parseInt(parts[2], 10);
    const months = [
      'Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno',
      'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'
    ];
    if (monthIndex >= 0 && monthIndex < 12) {
      return `${day} ${months[monthIndex]} ${year}`;
    }
  }
  return dateStr;
}

function formatNascita(dateStr: string) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    return `${parts[2]}/${parts[1]}/${parts[0]}`;
  }
  return dateStr;
}

function formatCerimoniaOra(dateTimeStr: string) {
  if (!dateTimeStr) return '';
  try {
    const d = new Date(dateTimeStr);
    if (isNaN(d.getTime())) return '';
    const hour = String(d.getHours()).padStart(2, '0');
    const min = String(d.getMinutes()).padStart(2, '0');
    return `ore ${hour}:${min}`;
  } catch {
    return '';
  }
}

function formatCerimoniaData(dateTimeStr: string) {
  if (!dateTimeStr) return '';
  try {
    const d = new Date(dateTimeStr);
    if (isNaN(d.getTime())) return '';
    const day = d.getDate();
    const months = [
      'Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno',
      'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'
    ];
    return `${day} ${months[d.getMonth()]} ${d.getFullYear()}`;
  } catch {
    return '';
  }
}

const dataMorteIta = formatMorte(defunto.data_morte);
const dataNascitaIta = formatNascita(defunto.data_nascita);
---

<Layout 
  title={`In Memoria di ${nomeCompleto} — FADI`}
  description={`Manifesto funebre di ${nomeCompleto}. Consulta gli orari delle cerimonie di commiato, invia un messaggio di cordoglio privato o lascia una firma.`}
>
  <!-- Memorial Header Section -->
  <section class="memorial-header-section">
    <div class="container header-grid">
      <!-- Left side: elegant photo representation -->
      <div class="memorial-photo-wrapper" style="display: flex; flex-direction: column; gap: 1.5rem; align-items: center; width: 100%; max-width: 320px; margin: 0 auto;">
        <div class="memorial-frame" style="width: 100%;">
          {haFoto ? (
            <img 
              src={defunto.foto_url} 
              alt={`Foto di ${nomeCompleto}`}
              class="memorial-image"
            />
          ) : (
            <div class="memorial-image-placeholder">
              <div class="placeholder-cross-lg">✝</div>
            </div>
          )}
          <div class="frame-gold-border"></div>
        </div>

        <div class="action-buttons-group-vertical" style="display: flex; flex-direction: column; gap: 0.75rem; width: 100%;">
          <a href="#cordoglio" class="btn btn-gold" style="width: 100%; justify-content: center; padding: 0.9rem 0;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            Invia Cordoglio
          </a>
          <a href="#firma-libro" class="btn btn-outline" style="width: 100%; justify-content: center; padding: 0.9rem 0;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
            </svg>
            Firma Libro Presenze
          </a>
        </div>
      </div>

      <!-- Right side: details and text -->
      <div class="memorial-primary-info">
        <div class="emblem" aria-hidden="true">✝</div>
        <span class="annuncio-label">In Memoria di</span>
        <h1 class="deceased-name">{nomeCompleto}</h1>
        
        <div class="dates-eta">
          {dataMorteIta && (
            <div class="info-tag">
              <span class="tag-title">Deceduto il:</span>
              <span class="tag-val">{dataMorteIta}</span>
            </div>
          )}
          {dataNascitaIta && (
            <div class="info-tag">
              <span class="tag-title">Nato il:</span>
              <span class="tag-val">{dataNascitaIta}</span>
            </div>
          )}
          {defunto.eta_visibile && defunto.eta && (
            <div class="info-tag">
              <span class="tag-title">Età:</span>
              <span class="tag-val">{defunto.eta} Anni</span>
            </div>
          )}
        </div>

        {annuncio.citazione && (
          <blockquote class="deceased-quote">
            <p>“{annuncio.citazione}”</p>
          </blockquote>
        )}

        {annuncio.epigrafe_url && (
          <div class="manifesto-preview-wrapper" style="cursor: pointer; width: 100%; max-width: 270px; margin-bottom: 2rem;">
            <div class="manifesto-thumbnail-card" id="open-manifesto-btn" style="position: relative; border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; background: #ffffff; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: all var(--transition);">
              <img src={annuncio.epigrafe_url} alt={`Manifesto di ${nomeCompleto}`} style="width: 100%; height: auto; display: block;" />
              <div class="manifesto-overlay" style="position: absolute; inset: 0; background: rgba(44, 38, 32, 0.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity var(--transition);">
                <span style="color: #ffffff; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #ffffff; padding: 0.4rem 0.8rem; border-radius: 4px; background: rgba(0,0,0,0.2);">Ingrandisci</span>
              </div>
            </div>
            <span style="display: block; margin-top: 0.5rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gold); text-align: center;">Manifesto Funebre</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Ceremony Details Grid -->
  <section class="section ceremonies-section">
    <div class="container">
      <div class="text-center section-header">
        <span class="section-label">Cerimonie</span>
        <h2 class="section-title">Orari & Luoghi del Commiato</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="ceremonies-grid">
        <!-- ROSARIO CARD -->
        {rosario.luogo || rosario.data_ora ? (
          <div class="ceremony-detail-card card">
            <div class="ceremony-header">
              <span class="ceremony-card-icon">📿</span>
              <h3>Santo Rosario</h3>
            </div>
            <div class="ceremony-body">
              {rosario.data_ora && (
                <div class="time-block">
                  <span class="time-date">{formatCerimoniaData(rosario.data_ora)}</span>
                  <span class="time-hours">{formatCerimoniaOra(rosario.data_ora)}</span>
                </div>
              )}
              <div class="address-block">
                <span class="place-name">{rosario.luogo || 'Presso la Chiesa'}</span>
                {rosario.indirizzo && <span class="place-address">{rosario.indirizzo}</span>}
              </div>
            </div>
            {rosario.link_maps && (
              <a href={rosario.link_maps} target="_blank" rel="noopener noreferrer" class="maps-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Indicazioni stradali
              </a>
            )}
          </div>
        ) : null}

        <!-- FUNERALE CARD -->
        {funerale.luogo || funerale.data_ora ? (
          <div class="ceremony-detail-card card card-highlighted">
            <div class="ceremony-header">
              <span class="ceremony-card-icon">✝</span>
              <h3>Cerimonia Funebre</h3>
            </div>
            <div class="ceremony-body">
              {funerale.data_ora && (
                <div class="time-block">
                  <span class="time-date">{formatCerimoniaData(funerale.data_ora)}</span>
                  <span class="time-hours">{formatCerimoniaOra(funerale.data_ora)}</span>
                </div>
              )}
              <div class="address-block">
                <span class="place-name">{funerale.luogo || 'Chiesa Parrocchiale'}</span>
                {funerale.indirizzo && <span class="place-address">{funerale.indirizzo}</span>}
              </div>
            </div>
            {funerale.link_maps && (
              <a href={funerale.link_maps} target="_blank" rel="noopener noreferrer" class="maps-link highlighted-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Indicazioni stradali
              </a>
            )}
          </div>
        ) : null}

        <!-- LUOGO DI RIPOSO CARD -->
        {luogoRiposo.luogo || luogoRiposo.indirizzo ? (
          <div class="ceremony-detail-card card">
            <div class="ceremony-header">
              <span class="ceremony-card-icon">🏠</span>
              <h3>Camera Ardente</h3>
            </div>
            <div class="ceremony-body">
              <div class="address-block" style="margin-top: 1rem;">
                <span class="place-name">{luogoRiposo.luogo}</span>
                {luogoRiposo.indirizzo && <span class="place-address">{luogoRiposo.indirizzo}</span>}
              </div>
            </div>
            {luogoRiposo.link_maps && (
              <a href={luogoRiposo.link_maps} target="_blank" rel="noopener noreferrer" class="maps-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Indicazioni stradali
              </a>
            )}
          </div>
        ) : null}

        <!-- SEPOLTURA CARD -->
        {sepoltura.luogo || sepoltura.indirizzo ? (
          <div class="ceremony-detail-card card">
            <div class="ceremony-header">
              <span class="ceremony-card-icon">🪦</span>
              <h3>Sepoltura</h3>
            </div>
            <div class="ceremony-body">
              <div class="address-block" style="margin-top: 1rem;">
                <span class="place-name">{sepoltura.luogo || 'Cimitero Comunale'}</span>
                {sepoltura.indirizzo && <span class="place-address">{sepoltura.indirizzo}</span>}
              </div>
            </div>
            {sepoltura.link_maps && (
              <a href={sepoltura.link_maps} target="_blank" rel="noopener noreferrer" class="maps-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Indicazioni stradali
              </a>
            )}
          </div>
        ) : null}
      </div>

      <!-- Live Stream Streaming Option -->
      {streaming.url_video && (
        <div class="streaming-block text-center">
          <div class="streaming-inner card">
            <span class="live-dot-pulse"></span>
            <h3>Diretta Streaming della Cerimonia</h3>
            <p>Per coloro che non possono partecipare fisicamente, è possibile seguire la cerimonia funebre in diretta streaming online.</p>
            <a href={streaming.url_video} target="_blank" rel="noopener noreferrer" class="btn btn-gold streaming-btn">
              ▶ Segui la diretta streaming
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Interactive Forms Section -->
  <section class="section interactive-memorial-section" id="interactive-area">
    <div class="container interactive-grid">
      <!-- CONDOLENCE FORM COLUMN -->
      <div class="condolence-column" id="cordoglio">
        <div class="interactive-card card">
          <div class="card-title-header">
            <h3>Esprimi il tuo Cordoglio</h3>
            <p>Invia un pensiero di affetto o un ricordo fotografico alla famiglia.</p>
          </div>

          <!-- Tab Selection Buttons -->
          <div class="memorial-tabs">
            <button type="button" class="tab-btn active" id="tab-btn-message">
              <span>✍️</span> Solo Messaggio
            </button>
            <button type="button" class="tab-btn" id="tab-btn-photo">
              <span>📸</span> Messaggio con Foto
            </button>
          </div>
          
          <!-- Content 1: Solo Messaggio Form -->
          <div id="form-container-message" class="tab-content">
            <form id="cordoglio-form" class="memorial-form">
              <div class="form-group">
                <label for="c-nome">Nome e Cognome *</label>
                <input type="text" id="c-nome" name="nome" placeholder="Esempio: Famiglia Rossi" required />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="c-telefono">Telefono *</label>
                  <input type="tel" id="c-telefono" name="telefono" placeholder="Esempio: 3331234567" required />
                </div>
                <div class="form-group">
                  <label for="c-mail">Email (Opzionale)</label>
                  <input type="email" id="c-mail" name="mail" placeholder="Esempio: nome@email.it" />
                </div>
              </div>

              <div class="form-group">
                <label for="c-testo">Il tuo Messaggio *</label>
                <textarea id="c-testo" name="testo" rows="5" placeholder="Scrivi qui le tue condoglianze..." required></textarea>
              </div>

              <div class="form-group checkbox-group" style="margin-top: 0.5rem; margin-bottom: 0.5rem;">
                <label class="checkbox-label" style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-size: 0.85rem; font-weight: normal; color: var(--text-muted); user-select: none;">
                  <input type="checkbox" id="c-visibile" name="visibile" checked style="accent-color: var(--gold); cursor: pointer; width: 18px; height: 18px; margin: 0;" />
                  <span>Rendi il messaggio pubblico (visibile online su AnnunciFunebri.it)</span>
                </label>
              </div>

              <div class="form-status" id="cordoglio-status"></div>

              <button type="submit" class="btn btn-gold btn-block" id="cordoglio-submit-btn">
                Invia Messaggio
              </button>
            </form>
          </div>

          <!-- Content 2: Messaggio con Foto Form -->
          <div id="form-container-photo" class="tab-content" style="display: none;">
            <form id="fotocordoglio-form" class="memorial-form">
              <div class="form-group">
                <label for="p-nome">Nome e Cognome *</label>
                <input type="text" id="p-nome" name="nome" placeholder="Esempio: Famiglia Rossi" required />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="p-telefono">Telefono *</label>
                  <input type="tel" id="p-telefono" name="telefono" placeholder="Esempio: 3331234567" required />
                </div>
                <div class="form-group">
                  <label for="p-mail">Email (Opzionale)</label>
                  <input type="email" id="p-mail" name="mail" placeholder="Esempio: nome@email.it" />
                </div>
              </div>

              <div class="form-group">
                <label for="p-testo">Il tuo Messaggio (Opzionale)</label>
                <textarea id="p-testo" name="testo" rows="4" placeholder="Scrivi qui le tue condoglianze..."></textarea>
              </div>

              <div class="form-group">
                <label>Seleziona le foto da allegare * (Max 3 foto)</label>
                <div class="photo-upload-zone" id="photo-dropzone">
                  <input type="file" id="photo-input" name="photos" accept="image/*" multiple style="display: none;" />
                  <div class="upload-zone-content">
                    <span class="upload-icon">📤</span>
                    <p class="upload-title">Trascina qui le tue foto o <strong>clicca per sfogliare</strong></p>
                    <p class="upload-subtitle">Formati supportati: JPG, PNG (max 10MB per foto)</p>
                  </div>
                </div>
                <div class="photo-preview-grid" id="photo-preview-grid" style="display: none;"></div>
              </div>

              <div class="form-group checkbox-group" style="margin-top: 0.5rem; margin-bottom: 0.5rem;">
                <label class="checkbox-label" style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-size: 0.85rem; font-weight: normal; color: var(--text-muted); user-select: none;">
                  <input type="checkbox" id="p-visibile" name="visibile" checked style="accent-color: var(--gold); cursor: pointer; width: 18px; height: 18px; margin: 0;" />
                  <span>Rendi il messaggio pubblico (visibile online su AnnunciFunebri.it)</span>
                </label>
              </div>

              <div class="form-status" id="fotocordoglio-status"></div>

              <button type="submit" class="btn btn-gold btn-block" id="fotocordoglio-submit-btn">
                Procedi al caricamento
              </button>
            </form>

            <!-- OTP Section -->
            <div id="otp-verification-section" style="display: none; border-top: 1px dashed var(--border); padding-top: 1.5rem; margin-top: 1.5rem;">
              <div class="card-title-header text-center">
                <h4>Verifica il tuo Foto-Cordoglio</h4>
                <p>Inserisci il codice OTP inviato tramite SMS al numero fornito.</p>
              </div>
              <form id="otp-form" class="memorial-form" style="max-width: 320px; margin: 0 auto;">
                <div class="form-group text-center">
                  <label for="otp-code">Codice OTP di verifica *</label>
                  <input type="text" id="otp-code" name="code" placeholder="Inserisci il codice" required style="text-align: center; font-size: 1.5rem; letter-spacing: 0.2em; max-width: 220px; margin: 0 auto;" />
                </div>
                <div class="form-status" id="otp-status"></div>
                <button type="submit" class="btn btn-gold btn-block" id="otp-submit-btn">
                  Conferma e Invia
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>

      <!-- SIGNATURE BOOK COLUMN -->
      <div class="signatures-column" id="firma-libro">
        <div class="interactive-card card">
          <div class="card-title-header">
            <h3>Libro delle Firme virtuale</h3>
            <p>Lascia una firma per attestare la tua presenza ed essere vicino ai familiari.</p>
          </div>

          <div class="signatures-view-container">
            <h4>Firme recenti</h4>
            <div class="signatures-list" id="signatures-list-container">
              <div class="loading-signatures">Caricamento in corso...</div>
            </div>
          </div>

          <form id="signature-form" class="memorial-form" style="border-top: 1px dashed var(--border); padding-top: 1.5rem; margin-top: 1.5rem;">
            <h4>Lascia la tua firma</h4>
            <div class="form-group">
              <label for="s-nome">Nome e Cognome *</label>
              <input type="text" id="s-nome" name="nominativo" placeholder="Esempio: Mario Rossi" required />
            </div>

            <div class="form-group">
              <label>Firma Calligrafica (Disegna nel riquadro sottostante)</label>
              <div class="canvas-wrapper">
                <canvas id="signature-canvas" width="400" height="150"></canvas>
                <button type="button" id="canvas-clear" class="canvas-clear-btn" title="Cancella disegno">&times; Cancella</button>
              </div>
            </div>

            <div class="form-status" id="signature-status"></div>

            <button type="submit" class="btn btn-outline btn-block" id="signature-submit-btn">
              Apponi Firma
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Manifesto Modal -->
  {annuncio.epigrafe_url && (
    <div id="manifesto-modal" class="manifesto-modal-overlay">
      <div class="manifesto-modal-content">
        <button id="close-manifesto-btn" class="close-manifesto-btn" type="button">
          &times;
        </button>
        <img src={annuncio.epigrafe_url} alt={`Manifesto Funebre di ${nomeCompleto}`} />
        <div class="manifesto-modal-caption">
          Manifesto Funebre di {nomeCompleto}
        </div>
      </div>
    </div>
  )}
</Layout>

<style>
  /* Memorial layout details */
  .memorial-header-section {
    background-color: var(--bg-soft);
    border-bottom: 1px solid var(--border);
    padding: 5rem 0;
  }

  .header-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .memorial-photo-wrapper {
    display: flex;
    justify-content: center;
  }

  .memorial-frame {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 3.2 / 4;
    border-radius: var(--radius);
    background-color: #ffffff;
    box-shadow: 0 10px 40px rgba(44, 38, 32, 0.08);
    overflow: hidden;
  }

  .memorial-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .memorial-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-soft) 0%, rgba(184, 150, 110, 0.03) 100%);
  }

  .placeholder-cross-lg {
