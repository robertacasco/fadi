</style>

<!-- Client Side Forms and Actions -->
<script define:vars={{ slug, defuntoNome: defunto.nome || '', defuntoCognome: defunto.cognome || '', nomeDefuntoCompleto: nomeCompleto || '' }}>
  const apiKey = 'ak_live_eQDEkmlEmMg7LxNcuE6WYLAXeQDEkmlE';
  
  // 1. SUBMIT CONDOLENCE ACTION
  const cordoglioForm = document.getElementById('cordoglio-form');
  const cordoglioStatus = document.getElementById('cordoglio-status');
  const cordoglioBtn = document.getElementById('cordoglio-submit-btn');

  cordoglioForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!cordoglioBtn || !cordoglioStatus) return;

    // Validate privacy checkbox explicitly
    const privacyChecked = document.getElementById('c-privacy')?.checked ?? false;
    if (!privacyChecked) {
      cordoglioStatus.className = 'form-status status-error';
      cordoglioStatus.style.display = 'block';
      cordoglioStatus.textContent = 'Errore: È necessario accettare l\'informativa sulla privacy per procedere.';
      return;
    }

    // Show loading state
    cordoglioBtn.disabled = true;
    const originalText = cordoglioBtn.innerHTML;
    cordoglioBtn.innerHTML = '<span class="spinner-inline"></span> Invio in corso...';
    
    cordoglioStatus.className = 'form-status status-info';
    cordoglioStatus.style.display = 'block';
    cordoglioStatus.textContent = 'Invio del messaggio alla famiglia in corso...';

    const formData = new FormData(cordoglioForm);
    
    // Inverted logic: if 'visibile solo alla famiglia' is checked, then isPublic is false
    const isPrivate = document.getElementById('c-visibile')?.checked ?? false;
    const isPublic = !isPrivate;

    // Append optional recapito/address to testo
    let textVal = formData.get('testo') || '';
    const addressVal = document.getElementById('c-recapito')?.value;
    if (addressVal && addressVal.trim() !== '') {
      textVal = textVal.trim() + "\n\nRecapito per ringraziamenti:\n" + addressVal.trim();
    }

    const payload = {
      slug: slug,
      nome: formData.get('nome'),
      telefono: formData.get('telefono'),
      mail: formData.get('mail') || null,
      testo: textVal,
      visibile: isPublic,
      provenienza: 1   // 1 indicates from website
    };

    try {
      const response = await fetch('/casper-api/public/v1/cordogli', {
        method: 'POST',
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.message || 'Errore di connessione al server.');
      }

      cordoglioStatus.className = 'form-status status-success';
      if (isPublic) {
        cordoglioStatus.textContent = 'Il tuo messaggio di cordoglio è stato inviato con successo e sarà visibile online su AnnunciFunebri.it.';
      } else {
        cordoglioStatus.textContent = 'Il tuo messaggio di cordoglio è stato inviato privatamente alla famiglia con successo.';
      }
      
      // Clear inputs
      cordoglioForm.reset();
    } catch (err) {
      cordoglioStatus.className = 'form-status status-error';
      cordoglioStatus.textContent = err.message || 'Si è verificato un errore durante l\'invio. Verifica i dati o riprova più tardi.';
    } finally {
      cordoglioBtn.disabled = false;
      cordoglioBtn.innerHTML = originalText;
    }
  });

  // 5. TABS SWITCHING LOGIC
  const tabBtnMessage = document.getElementById('tab-btn-message');
  const tabBtnPhoto = document.getElementById('tab-btn-photo');
  const containerMessage = document.getElementById('form-container-message');
  const containerPhoto = document.getElementById('form-container-photo');

  tabBtnMessage?.addEventListener('click', () => {
    tabBtnMessage.classList.add('active');
    tabBtnPhoto.classList.remove('active');
    if (containerMessage) containerMessage.style.display = 'block';
    if (containerPhoto) containerPhoto.style.display = 'none';
  });

  tabBtnPhoto?.addEventListener('click', () => {
    tabBtnPhoto.classList.add('active');
    tabBtnMessage.classList.remove('active');
    if (containerPhoto) containerPhoto.style.display = 'block';
    if (containerMessage) containerMessage.style.display = 'none';
  });

  // Hero "Invia una Foto" button → scroll to section and activate photo tab
  document.getElementById('hero-btn-photo')?.addEventListener('click', () => {
    tabBtnPhoto?.click();
  });

  // 6. PHOTO SELECTION AND PREVIEW
  const photoDropzone = document.getElementById('photo-dropzone');
  const photoInput = document.getElementById('photo-input');
  const photoPreviewGrid = document.getElementById('photo-preview-grid');
  let selectedFiles = [];

  photoDropzone?.addEventListener('click', () => {
    photoInput?.click();
  });

  photoDropzone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    photoDropzone.classList.add('dragover');
  });

  photoDropzone?.addEventListener('dragleave', () => {
    photoDropzone.classList.remove('dragover');
  });

  photoDropzone?.addEventListener('drop', (e) => {
    e.preventDefault();
    photoDropzone.classList.remove('dragover');
    if (e.dataTransfer.files) {
      handleFiles(e.dataTransfer.files);
    }
  });

  photoInput?.addEventListener('change', (e) => {
    if (e.target.files) {
      handleFiles(e.target.files);
    }
  });

  function handleFiles(files) {
    const filesArr = Array.from(files);
    if (selectedFiles.length + filesArr.length > 3) {
      alert('Puoi selezionare al massimo 3 foto.');
      return;
    }

    filesArr.forEach(file => {
      if (!file.type.startsWith('image/')) {
        alert('Solo file immagine sono supportati.');
        return;
      }
      if (file.size > 10 * 1024 * 1024) {
        alert('Ogni immagine deve essere inferiore a 10MB.');
        return;
      }
      selectedFiles.push(file);
    });

    updatePreviews();
  }

  function updatePreviews() {
    if (!photoPreviewGrid) return;

    if (selectedFiles.length === 0) {
      photoPreviewGrid.style.display = 'none';
      photoPreviewGrid.innerHTML = '';
      return;
    }

    photoPreviewGrid.style.display = 'grid';
    photoPreviewGrid.innerHTML = '';

    selectedFiles.forEach((file, index) => {
      const previewItem = document.createElement('div');
      previewItem.className = 'photo-preview-item';

      const img = document.createElement('img');
      img.className = 'photo-preview-img';
      img.src = URL.createObjectURL(file);
      previewItem.appendChild(img);

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'photo-remove-btn';
      removeBtn.innerHTML = '&times;';
      removeBtn.addEventListener('click', () => {
        selectedFiles.splice(index, 1);
        updatePreviews();
      });
      previewItem.appendChild(removeBtn);

      photoPreviewGrid.appendChild(previewItem);
    });
  }

  // 7. SUBMIT PHOTO CONDOLENCE (ALBUM CREATE & UPLOAD)
  const fotocordoglioForm = document.getElementById('fotocordoglio-form');
  const fotocordoglioStatus = document.getElementById('fotocordoglio-status');
  const fotocordoglioBtn = document.getElementById('fotocordoglio-submit-btn');
  const otpSection = document.getElementById('otp-verification-section');
  let activeAlbumId = null;
  let activeVerificationCode = null;

  fotocordoglioForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!fotocordoglioBtn || !fotocordoglioStatus) return;

    // Validate privacy checkbox
    const photoPrivacyChecked = document.getElementById('p-privacy')?.checked ?? false;
    if (!photoPrivacyChecked) {
      fotocordoglioStatus.className = 'form-status status-error';
      fotocordoglioStatus.style.display = 'block';
      fotocordoglioStatus.textContent = 'Errore: È necessario accettare l\'informativa sulla privacy per procedere.';
      return;
    }

    if (selectedFiles.length === 0) {
      fotocordoglioStatus.className = 'form-status status-error';
      fotocordoglioStatus.style.display = 'block';
      fotocordoglioStatus.textContent = 'Errore: Per favore, seleziona almeno una foto da allegare.';
      return;
    }

    // Show loading
    fotocordoglioBtn.disabled = true;
    const originalText = fotocordoglioBtn.innerHTML;
    fotocordoglioBtn.innerHTML = '<span class="spinner-inline"></span> Creazione album...';
    fotocordoglioStatus.className = 'form-status status-info';
    fotocordoglioStatus.style.display = 'block';
    fotocordoglioStatus.textContent = 'Creazione album di foto-cordoglio...';

    const formData = new FormData(fotocordoglioForm);
    const nome = formData.get('nome');
    const telefono = formData.get('telefono');
    const mail = formData.get('mail') || null;
    const testo = formData.get('testo') || '';

    const isPublic = document.getElementById('p-visibile')?.checked ?? true;
    const payload = {
      slug: slug,
      nome: nome,
      nominativo: nome,
      telefono: telefono,
      mail: mail,
      email: mail,
      testo: testo,
      nome_defunto: defuntoNome,
      cognome_defunto: defuntoCognome,
      visibile: isPublic,
      provenienza: 1
    };

    try {
      // Step A: Create empty album
      const createRes = await fetch('/casper-api/public/v1/fotocordogli/albums/create', {
        method: 'POST',
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      const createJson = await createRes.json();
      if (!createRes.ok || !createJson.success) {
        throw new Error(createJson.message || createJson.data?.message || 'Errore nella creazione dell\'album.');
      }

      const albumId = createJson.data?.album_id || createJson.data?.id || createJson.id;
      if (!albumId) {
        throw new Error('ID dell\'album non restituito dal server. Risposta: ' + JSON.stringify(createJson));
      }
      activeAlbumId = albumId;
      activeVerificationCode = createJson.data?.codice_verifica || null;

      // Step B: Upload each photo
      for (let i = 0; i < selectedFiles.length; i++) {
        const file = selectedFiles[i];
        fotocordoglioStatus.textContent = `Caricamento foto ${i + 1} di ${selectedFiles.length}...`;
        fotocordoglioBtn.innerHTML = `<span class="spinner-inline"></span> Foto ${i + 1}/${selectedFiles.length}...`;

        const fileData = new FormData();
        fileData.append('foto', file);

        const uploadRes = await fetch(`/casper-api/public/v1/fotocordogli/albums/${albumId}/add-photo`, {
          method: 'POST',
          headers: {
            'X-API-Key': apiKey,
            'Accept': 'application/json'
          },
          body: fileData
        });

        const uploadJson = await uploadRes.json();
        if (!uploadRes.ok) {
          throw new Error(uploadJson.message || `Errore nel caricamento della foto ${i + 1}.`);
        }
      }

      // Step C: Finalize album
      fotocordoglioStatus.textContent = 'Finalizzazione e invio codice di verifica...';
      fotocordoglioBtn.innerHTML = '<span class="spinner-inline"></span> Finalizzazione...';

      const finalizeRes = await fetch(`/casper-api/public/v1/fotocordogli/albums/${albumId}/finalize`, {
        method: 'POST',
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({})
      });

      const finalizeJson = await finalizeRes.json();
      if (!finalizeRes.ok) {
        throw new Error(finalizeJson.message || 'Errore nella finalizzazione dell\'album.');
      }

      fotocordoglioStatus.className = 'form-status status-success';
      fotocordoglioStatus.textContent = 'Album caricato con successo. Per completare l\'invio, inserisci il codice OTP ricevuto tramite SMS.';
      
      // Hide upload button & show OTP form
      fotocordoglioBtn.style.display = 'none';
      if (otpSection) {
        otpSection.style.display = 'block';
        otpSection.scrollIntoView({ behavior: 'smooth' });
      }

    } catch (err) {
      fotocordoglioStatus.className = 'form-status status-error';
      fotocordoglioStatus.textContent = err.message || 'Si è verificato un errore durante l\'invio delle foto. Riprova più tardi.';
      fotocordoglioBtn.disabled = false;
      fotocordoglioBtn.innerHTML = originalText;
    }
  });

  // 8. VERIFY OTP CODE
  const otpForm = document.getElementById('otp-form');
  const otpStatus = document.getElementById('otp-status');
  const otpBtn = document.getElementById('otp-submit-btn');

  otpForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!otpBtn || !otpStatus || !activeAlbumId) return;

    // Show loading
    otpBtn.disabled = true;
    const originalText = otpBtn.innerHTML;
    otpBtn.innerHTML = '<span class="spinner-inline"></span> Verifica...';
    otpStatus.className = 'form-status status-info';
    otpStatus.style.display = 'block';
    otpStatus.textContent = 'Verifica del codice OTP...';

    const formData = new FormData(otpForm);
    const otpCode = formData.get('code');

    const payload = {
      album_id: activeAlbumId,
      codice_verifica: activeVerificationCode || otpCode
    };

    try {
      const verifyRes = await fetch('/casper-api/public/v1/fotocordogli/verify', {
        method: 'POST',
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      const verifyJson = await verifyRes.json();
      if (!verifyRes.ok || (!verifyJson.success && verifyJson.error)) {
        throw new Error(verifyJson.message || 'Il codice inserito non è corretto o è scaduto.');
      }

      const isPublic = document.getElementById('p-visibile')?.checked ?? true;
      otpStatus.className = 'form-status status-success';
      if (isPublic) {
        otpStatus.textContent = 'Il tuo foto-cordoglio è stato inviato, confermato con successo e sarà visibile online! Grazie per la vicinanza.';
      } else {
        otpStatus.textContent = 'Il tuo foto-cordoglio è stato inviato privatamente alla famiglia e confermato con successo! Grazie per la vicinanza.';
      }
      
      // Reset entire view
      selectedFiles = [];
      updatePreviews();
      if (fotocordoglioForm) fotocordoglioForm.reset();
      otpForm.reset();
      
      setTimeout(() => {
        if (otpSection) otpSection.style.display = 'none';
        if (fotocordoglioBtn) {
          fotocordoglioBtn.style.display = 'block';
          fotocordoglioBtn.disabled = false;
          fotocordoglioBtn.innerHTML = 'Procedi al caricamento';
        }
        if (fotocordoglioStatus) fotocordoglioStatus.style.display = 'none';
        otpStatus.style.display = 'none';
        
        // Switch back to message tab
        tabBtnMessage?.click();
      }, 4000);

    } catch (err) {
      otpStatus.className = 'form-status status-error';
      otpStatus.textContent = err.message || 'Errore nella convalida. Verifica il codice e riprova.';
      otpBtn.disabled = false;
      otpBtn.innerHTML = originalText;
    }
  });

  // 9. MANIFESTO MODAL ACTIONS
  const openManifesto = document.getElementById('open-manifesto-btn');
  const closeManifesto = document.getElementById('close-manifesto-btn');
  const modal = document.getElementById('manifesto-modal');
  
  if (openManifesto && modal && closeManifesto) {
    openManifesto.addEventListener('click', () => {
      modal.style.display = 'flex';
      modal.offsetHeight; // force reflow for opacity transition
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    });
    
    const closeModal = () => {
      modal.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(() => {
        modal.style.display = 'none';
      }, 300);
    };
    
    closeManifesto.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });
  }

  // 10. PRESET MODAL ACTIONS
  const openPresets = document.getElementById('open-presets-btn');
  const closePresets = document.getElementById('close-presets-btn');
  const presetsModal = document.getElementById('presets-modal');
  const presetButtons = document.querySelectorAll('.preset-option-btn');
  const messageTextarea = document.getElementById('c-testo');

  if (openPresets && presetsModal && closePresets) {
    openPresets.addEventListener('click', (e) => {
      e.preventDefault();
      presetsModal.style.display = 'flex';
      presetsModal.offsetHeight; // force reflow
      presetsModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    });

    const closePresetsModal = () => {
      presetsModal.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(() => {
        presetsModal.style.display = 'none';
      }, 300);
    };

    closePresets.addEventListener('click', closePresetsModal);
    presetsModal.addEventListener('click', (e) => {
      if (e.target === presetsModal) {
        closePresetsModal();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && presetsModal.classList.contains('active')) {
        closePresetsModal();
      }
    });

    // Option selection
    presetButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = btn.textContent.replace(/^"|"$/g, ''); // strip outer quotes if any
        if (messageTextarea) {
          messageTextarea.value = text;
        }
        closePresetsModal();
      });
    });
  }

  // ============================================
  // FIORI / FLOWER ORDER — INLINE FORM
  // ============================================
  const fioriFormWrap    = document.getElementById('fiori-inline-form-wrap');
  const fioriOrderForm   = document.getElementById('fiori-order-form');
  const fioriOrderStatus = document.getElementById('fiori-order-status');
  const fioriCancelBtn   = document.getElementById('fiori-cancel-btn');

  let selectedFlowerProduct = '';
  let selectedFlowerPrice   = '';

  function showFioriForm(productName, productPrice) {
    selectedFlowerProduct = productName;
    selectedFlowerPrice   = productPrice;

    // Product header
    const nameEl  = document.getElementById('fiori-inline-product-name');
    const priceEl = document.getElementById('fiori-inline-product-price');
    if (nameEl)  nameEl.textContent  = productName;
    if (priceEl) priceEl.textContent = `€ ${productPrice} IVA inclusa`;

    // Auto-fill defunto field
    const defuntoInput = document.getElementById('fiori-defunto');
    if (defuntoInput) defuntoInput.value = nomeDefuntoCompleto || '';

    // Price summary
    const summaryLabel = document.getElementById('fiori-summary-label');
    const summaryPrice = document.getElementById('fiori-summary-price');
    const summaryTotal = document.getElementById('fiori-summary-total');
    if (summaryLabel) summaryLabel.textContent = `Prezzo del prodotto €${productPrice} x 1`;
    if (summaryPrice) summaryPrice.textContent = `€${productPrice}`;
    if (summaryTotal) summaryTotal.textContent = `€${productPrice}`;

    // Reset form fields (except defunto)
    const mittente = document.getElementById('fiori-mittente');
    const nastro   = document.getElementById('fiori-nastro');
    const biglietto= document.getElementById('fiori-biglietto');
    const luogo    = document.getElementById('fiori-luogo');
    const note     = document.getElementById('fiori-note');
    const privacy  = document.getElementById('fiori-privacy');
    if (mittente)  mittente.value  = '';
    if (nastro)    nastro.value    = '';
    if (biglietto) biglietto.value = '';
    if (luogo)     luogo.value     = '';
    if (note)      note.value      = '';
    if (privacy)   privacy.checked = false;
    document.querySelectorAll('input[name="pagamento"]').forEach(r => r.checked = false);
    document.getElementById('nastro-count') && (document.getElementById('nastro-count').textContent = '0');
    document.getElementById('biglietto-count') && (document.getElementById('biglietto-count').textContent = '0');
    if (fioriOrderStatus) { fioriOrderStatus.style.display = 'none'; fioriOrderStatus.textContent = ''; }

    // Show form and scroll to it
    if (fioriFormWrap) {
      fioriFormWrap.style.display = 'block';
      setTimeout(() => fioriFormWrap.scrollIntoView({ behavior: 'smooth', block: 'start' }), 60);
    }

    // Highlight selected card
    document.querySelectorAll('.fiori-card').forEach(card => {
      card.classList.toggle('fiori-card-selected', card.dataset.product === productName);
    });
  }

  function hideFioriForm() {
    if (fioriFormWrap) fioriFormWrap.style.display = 'none';
    document.querySelectorAll('.fiori-card').forEach(c => c.classList.remove('fiori-card-selected'));
  }

  // "Scegli" buttons
  document.querySelectorAll('.fiori-order-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      showFioriForm(btn.dataset.product || '', btn.dataset.price || '');
    });
  });

  // Cancel button
  fioriCancelBtn?.addEventListener('click', hideFioriForm);

  // Char counters
  document.getElementById('fiori-nastro')?.addEventListener('input', function() {
    const el = document.getElementById('nastro-count');
    if (el) el.textContent = this.value.length;
  });
  document.getElementById('fiori-biglietto')?.addEventListener('input', function() {
    const el = document.getElementById('biglietto-count');
    if (el) el.textContent = this.value.length;
  });

  // Form submit → WhatsApp
  fioriOrderForm?.addEventListener('submit', (e) => {
    e.preventDefault();

    const privacyOk = document.getElementById('fiori-privacy')?.checked ?? false;
    if (!privacyOk) {
      if (fioriOrderStatus) {
        fioriOrderStatus.className = 'form-status status-error';
        fioriOrderStatus.style.display = 'block';
        fioriOrderStatus.textContent = 'È necessario accettare l\'informativa sulla privacy.';
      }
      return;
    }

    const mittente  = document.getElementById('fiori-mittente')?.value.trim()  || '';
    const defunto   = document.getElementById('fiori-defunto')?.value.trim()   || '';
    const nastro    = document.getElementById('fiori-nastro')?.value.trim()    || '';
    const biglietto = document.getElementById('fiori-biglietto')?.value.trim() || '';
    const luogo     = document.getElementById('fiori-luogo')?.value.trim()     || '';
    const note      = document.getElementById('fiori-note')?.value.trim()      || '';
    const pagamento = document.querySelector('input[name="pagamento"]:checked')?.value || '';

    if (!mittente || !luogo) {
      if (fioriOrderStatus) {
        fioriOrderStatus.className = 'form-status status-error';
        fioriOrderStatus.style.display = 'block';
        fioriOrderStatus.textContent = 'Il tuo nome e il luogo di consegna sono obbligatori.';
      }
      return;
    }

    if (!pagamento) {
      if (fioriOrderStatus) {
        fioriOrderStatus.className = 'form-status status-error';
        fioriOrderStatus.style.display = 'block';
        fioriOrderStatus.textContent = 'Seleziona un metodo di pagamento.';
      }
      return;
    }

    // Build WhatsApp message
    let msg = `🌸 *Ordine composizione floreale*\n\n`;
    msg += `*Composizione:* ${selectedFlowerProduct}\n`;
    msg += `*Prezzo:* € ${selectedFlowerPrice}\n\n`;
    msg += `*Mittente:* ${mittente}\n`;
    msg += `*Defunto:* ${defunto}\n`;
    if (nastro)    msg += `*Scritta sul nastro:* ${nastro}\n`;
    if (biglietto) msg += `*Biglietto:* ${biglietto}\n`;
    msg += `*Luogo di consegna:* ${luogo}\n`;
    if (note)      msg += `*Note:* ${note}\n`;
    msg += `*Pagamento:* ${pagamento}\n`;
    msg += `\n_Inviato tramite servizifadi.it_`;

    const waNumber = '390963353321';
    const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`;
    window.open(waUrl, '_blank', 'noopener,noreferrer');
  });
</script>
