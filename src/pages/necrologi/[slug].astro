    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    transition: all var(--transition);
  }

  .maps-link:hover {
    color: var(--gold);
    border-color: var(--gold);
    background-color: var(--bg-soft);
  }

  .highlighted-link {
    background-color: var(--gold-dim);
    border-color: var(--gold);
    color: var(--gold);
  }

  .highlighted-link:hover {
    background-color: var(--gold);
    color: #1a1f2e;
  }

  /* Streaming info */
  .streaming-block {
    margin-top: 4.5rem;
  }

  .streaming-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem;
    position: relative;
    border-color: #4ade80; /* Elegant soft green border for live streaming activity */
    background: linear-gradient(to bottom, #ffffff 0%, rgba(74, 222, 128, 0.01) 100%);
  }

  .live-dot-pulse {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
    animation: livePulse 2s infinite;
  }

  @keyframes livePulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.5; }
  }

  .streaming-inner h3 {
    font-size: 1.45rem;
    margin-bottom: 0.5rem;
  }

  .streaming-inner p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .streaming-btn {
    border: none;
    background-color: #4ade80;
    color: #111827;
  }

  .streaming-btn:hover {
    background-color: #2ecc71;
    color: #111827;
    box-shadow: 0 6px 24px rgba(46, 204, 113, 0.25);
  }

  /* Interactive section split */
  .interactive-memorial-section {
    background-color: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .interactive-grid {
    display: block;
    max-width: 820px;
    margin: 0 auto;
  }

  .interactive-card {
    padding: 3rem 2.5rem;
    background-color: #ffffff;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .card-title-header {
    margin-bottom: 2rem;
  }

  .card-title-header h3 {
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .card-title-header p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Forms general styling */
  .memorial-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .memorial-form label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
  }

  .memorial-form input, .memorial-form textarea {
    padding: 0.85rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    outline: none;
    transition: all var(--transition);
  }

  .memorial-form input:focus, .memorial-form textarea:focus {
    border-color: var(--gold);
    background-color: #ffffff;
    box-shadow: 0 4px 16px rgba(184, 150, 110, 0.08);
  }

  .btn-block {
    width: 100%;
    justify-content: center;
    padding: 1rem 0;
  }

  /* Feedback status */
  .form-status {
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-top: 0.5rem;
    display: none;
    font-weight: 500;
  }

  .status-success {
    display: block;
    background-color: rgba(46, 204, 113, 0.1);
    color: #27ae60;
    border: 1px solid rgba(46, 204, 113, 0.2);
  }

  .status-error {
    display: block;
    background-color: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid rgba(231, 76, 60, 0.2);
  }

  .status-info {
    display: block;
    background-color: var(--gold-dim);
    color: var(--gold);
    border: 1px solid var(--border);
  }

  /* Spinner */
  .spinner-inline {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: rotateSpinner 0.8s linear infinite;
    vertical-align: -2px;
    margin-right: 0.5rem;
  }

  @keyframes rotateSpinner {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (max-width: 900px) {
    .header-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .memorial-photo-wrapper {
      max-width: 260px;
      margin: 0 auto;
    }

    .memorial-primary-info {
      align-items: center;
    }

    .deceased-quote {
      text-align: center;
      border-left: none;
      border-top: 1px dashed var(--border);
      border-bottom: 1px dashed var(--border);
      padding: 1rem 0;
      margin: 1.5rem 0;
    }

    .dates-eta {
      justify-content: center;
    }

    .action-buttons-group {
      justify-content: center;
      width: 100%;
    }

    .action-buttons-group .btn {
      width: 100%;
      justify-content: center;
    }

    .interactive-card {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* Tabs for condolence types */
  :global(.memorial-tabs) {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 0.5rem !important;
    background-color: var(--bg-soft, #f8f6f2) !important;
    padding: 0.35rem !important;
    border-radius: 8px !important;
    margin-bottom: 2rem !important;
    border: 1px solid var(--border, #e5e0d8) !important;
  }

  :global(.tab-btn) {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.5rem !important;
    padding: 0.75rem 1.25rem !important;
    font-family: var(--font-sans), sans-serif !important;
    font-size: 0.88rem !important;
    font-weight: 700 !important;
    color: var(--text-muted, #70665C) !important;
    background: transparent !important;
    border: none !important;
    border-radius: 6px !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    box-shadow: none !important;
    outline: none !important;
    -webkit-appearance: none !important;
    appearance: none !important;
  }

  :global(.tab-btn:hover) {
    color: var(--text, #2C2620) !important;
    background-color: rgba(184, 150, 110, 0.04) !important;
  }

  :global(.tab-btn.active) {
    background-color: #ffffff !important;
    color: var(--gold, #b8966e) !important;
    box-shadow: 0 4px 12px rgba(44, 38, 32, 0.08) !important;
  }

  /* Photo upload dropzone */
  .photo-upload-zone {
    border: 2px dashed rgba(184, 150, 110, 0.4);
    background-color: var(--bg);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: all var(--transition);
  }

  .photo-upload-zone:hover, .photo-upload-zone.dragover {
    border-color: var(--gold);
    background-color: rgba(184, 150, 110, 0.04);
  }

  .upload-zone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .upload-icon {
    font-size: 2.2rem;
  }

  .upload-title {
    font-size: 0.9rem;
    color: var(--text);
  }

  .upload-title strong {
    color: var(--gold);
  }

  .upload-subtitle {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Photo preview grid */
  .photo-preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .photo-preview-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .photo-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-remove-btn {
    position: absolute;
    top: 4px;
    right: 4px;
    background: rgba(231, 76, 60, 0.9);
    color: #ffffff;
    border: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    font-size: 0.75rem;
    line-height: 20px;
    text-align: center;
    cursor: pointer;
    transition: background-color var(--transition);
    padding: 0;
  }

  .photo-remove-btn:hover {
    background: #c0392b;
  }

  /* Manifesto Thumbnail Hover & Interaction */
  .manifesto-thumbnail-card:hover {
    transform: translateY(-4px);
    border-color: var(--gold) !important;
    box-shadow: 0 8px 24px rgba(184, 150, 110, 0.15) !important;
  }
  .manifesto-thumbnail-card:hover .manifesto-overlay {
    opacity: 1 !important;
  }

  /* Manifesto Modal Styles */
  :global(.manifesto-modal-overlay) {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: rgba(26, 31, 46, 0.85);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  :global(.manifesto-modal-overlay.active) {
    display: flex !important;
    opacity: 1 !important;
  }
  :global(.manifesto-modal-content) {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    background: #ffffff;
    padding: 0.75rem;
    border-radius: var(--radius);
    border: 2px solid var(--gold);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    transform: scale(0.9);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  :global(.manifesto-modal-overlay.active .manifesto-modal-content) {
    transform: scale(1) !important;
  }
  :global(.manifesto-modal-content img) {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: calc(var(--radius) - 4px);
  }
  :global(.manifesto-modal-caption) {
    text-align: center;
    margin-top: 0.75rem;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }
  :global(.close-manifesto-btn) {
    position: absolute;
    top: -1.75rem;
    right: -1.75rem;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3) !important;
    background: rgba(0, 0, 0, 0.5) !important;
    color: #ffffff !important;
    font-size: 1.5rem !important;
    line-height: 2rem;
    text-align: center;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
  }
  :global(.close-manifesto-btn:hover) {
    background-color: var(--gold) !important;
    border-color: var(--gold) !important;
    transform: rotate(90deg);
  }

  /* --- Burgundy theme and form enhancements --- */
  :root {
    --burgundy: #6b1426;
  }

  .condolence-intro-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px dashed var(--border);
    padding-bottom: 1.5rem;
  }

  .condolence-main-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--burgundy);
    margin-bottom: 0.5rem;
  }

  .condolence-intro-text {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.6;
    margin: 0;
  }

  .condolence-intro-text strong {
    font-weight: 700;
  }

  .condolence-intro-text.text-light {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .burgundy-link {
    color: var(--burgundy) !important;
    font-weight: 700;
    text-decoration: underline !important;
    transition: color var(--transition);
  }

  .burgundy-link:hover {
    color: var(--gold) !important;
  }

  .btn-burgundy {
    background-color: var(--burgundy);
    color: #ffffff !important;
    font-family: var(--font-sans);
    font-weight: 700;
    border: none;
    letter-spacing: 0.05em;
    transition: all var(--transition);
  }

  .btn-burgundy:hover {
    background-color: #550f1d;
    box-shadow: 0 4px 12px rgba(107, 20, 38, 0.2);
  }

  .btn-outline-gold {
    background-color: transparent;
    color: var(--gold) !important;
    font-family: var(--font-sans);
    font-weight: 700;
    border: 1.5px solid var(--gold) !important;
    letter-spacing: 0.05em;
    transition: all var(--transition);
  }

  .btn-outline-gold:hover {
    background-color: var(--gold);
    color: #1a1f2e !important;
    box-shadow: 0 4px 12px rgba(184, 150, 110, 0.25);
  }

  .address-recapito-block {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    background-color: var(--bg-soft);
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    text-align: left;
  }

  .address-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  /* Visually hidden helper for clean semantic markup */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ==========================================
     FIORI / FLOWER E-COMMERCE SECTION
     ========================================== */
  .fiori-section {
    background: linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 100%);
    border-top: 1px solid var(--border);
  }

  .fiori-intro-text {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 680px;
    margin: 1.25rem auto 0.5rem;
  }

  .fiori-disclaimer {
    font-size: 0.78rem;
    color: var(--text-muted);
    opacity: 0.75;
    max-width: 600px;
    margin: 0.5rem auto 0;
    font-style: italic;
  }

  .fiori-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .fiori-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .fiori-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }

  .fiori-card-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f8f6f2;
  }

  .fiori-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .fiori-card:hover .fiori-card-img {
    transform: scale(1.04);
  }

  .fiori-card-selected {
    border-color: var(--gold) !important;
    box-shadow: 0 0 0 2px var(--gold), 0 8px 24px rgba(184,150,110,0.18) !important;
  }

  .fiori-card-selected .fiori-order-btn {
    background: var(--gold) !important;
    color: #fff !important;
    border-color: var(--gold) !important;
  }

  .fiori-card-body {
    padding: 1.1rem 1.2rem 1.2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.4rem;
  }

  .fiori-card-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
  }

  .fiori-card-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .fiori-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.75rem;
    gap: 0.5rem;
  }

  .fiori-price {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.02em;
  }

  .fiori-order-btn {
    padding: 0.5rem 1rem !important;
    font-size: 0.82rem !important;
    letter-spacing: 0.06em;
  }

  /* FIORI MODAL */
  .fiori-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeInOverlay 0.2s ease;
  }

  @keyframes fadeInOverlay {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .fiori-modal-box {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    width: 100%;
    max-width: 460px;
    position: relative;
    animation: slideUpModal 0.25s ease;
    max-height: 90vh;
    overflow-y: auto;
  }

  @keyframes slideUpModal {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fiori-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }

  .fiori-modal-close:hover {
    color: var(--text);
    background: var(--bg-soft);
  }

  .fiori-modal-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-right: 2rem;
  }

  .fiori-modal-header h3 {
    margin: 0 0 0.2rem;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--text);
  }

  .fiori-modal-product-name {
    color: var(--gold);
    font-weight: 600;
    font-size: 0.9rem;
    margin: 0;
  }

  .gold-link {
    color: var(--gold);
    text-decoration: underline;
    font-weight: 600;
  }

  /* INLINE ORDER FORM */
  .fiori-inline-form-wrap {
    margin-top: 2.5rem;
    animation: slideUpModal 0.3s ease;
  }

  .fiori-inline-form-inner {
    padding: 2rem 2.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--card-bg);
  }

  .fiori-inline-product-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .fiori-inline-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }

  .fiori-inline-product-name {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: var(--text);
    margin: 0 0 0.15rem;
  }

  .fiori-inline-product-price {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold);
    margin: 0;
  }

  .fiori-cancel-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.45rem 0.9rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--transition);
    white-space: nowrap;
  }

  .fiori-cancel-btn:hover {
    border-color: var(--burgundy);
    color: var(--burgundy);
  }

  .fiori-order-form-grid {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .fiori-form-full { width: 100%; }

  .fiori-req { color: var(--burgundy); }

  .fiori-field-hint {
    display: block;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    margin-top: 0.15rem;
    line-height: 1.45;
  }

  .fiori-readonly-input {
    background: var(--bg-soft) !important;
    color: var(--text-muted) !important;
    cursor: default !important;
    font-weight: 600;
  }

  .fiori-char-count {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
    margin-top: 0.2rem;
  }

  /* Price summary */
  .fiori-price-summary {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 0;
    margin: 0.75rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fiori-price-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

