---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const apiKey = 'ak_live_eQDEkmlEmMg7LxNcuE6WYLAXeQDEkmlE';
  const apiUrl = 'https://api.cas-per.it/api/public/v1/annunci?limit=100';
  
  try {
    const res = await fetch(apiUrl, {
      headers: {
        'X-API-Key': apiKey,
        'Accept': 'application/json'
      }
    });

    if (!res.ok) {
      throw new Error(`getStaticPaths failed: ${res.status}`);
    }

    const json = await res.json();
    const items = json.data || [];
    
    return items.map((item: any) => ({
      params: { slug: item.slug },
      props: { item }
    }));
  } catch (err) {
    console.error('Error generating static paths for necrologi:', err);
    return [];
  }
}

const { slug } = Astro.params;
const { item } = Astro.props;

if (!item) {
  return Astro.redirect('/404');
}

const defunto = item.defunto || {};
const annuncio = item.annuncio || {};
const funerale = item.funerale || {};
const rosario = item.rosario || {};
const sepoltura = item.sepoltura || {};
const luogoRiposo = item.luogo_riposo || {};
const streaming = item.streaming || {};
const nomeCompleto = item.nominativo || `${defunto.nome || ''} ${defunto.cognome || ''}`.trim();
const haFoto = !!defunto.foto_url;

function formatMorte(dateStr: string) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    const year = parts[0];
    const monthIndex = parseInt(parts[1], 10) - 1;
    const day = parseInt(parts[2], 10);
    const months = [
      'Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno',
      'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'
    ];
    if (monthIndex >= 0 && monthIndex < 12) {
      return `${day} ${months[monthIndex]} ${year}`;
    }
  }
  return dateStr;
}

function formatNascita(dateStr: string) {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    return `${parts[2]}/${parts[1]}/${parts[0]}`;
  }
  return dateStr;
}

function formatCerimoniaOra(dateTimeStr: string) {
  if (!dateTimeStr) return '';
  try {
    const d = new Date(dateTimeStr);
    if (isNaN(d.getTime())) return '';
    const hour = String(d.getHours()).padStart(2, '0');
    const min = String(d.getMinutes()).padStart(2, '0');
    return `ore ${hour}:${min}`;
  } catch {
    return '';
  }
}

function formatCerimoniaData(dateTimeStr: string) {
  if (!dateTimeStr) return '';
  try {
    const d = new Date(dateTimeStr);
    if (isNaN(d.getTime())) return '';
    const day = d.getDate();
    const months = [
      'Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno',
      'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'
    ];
    return `${day} ${months[d.getMonth()]} ${d.getFullYear()}`;
  } catch {
    return '';
  }
}

const dataMorteIta = formatMorte(defunto.data_morte);
const dataNascitaIta = formatNascita(defunto.data_nascita);
---

