</style>

<!-- Client Side Forms and Canvas Actions -->
<script define:vars={{ slug }}>
  const apiKey = 'ak_live_eQDEkmlEmMg7LxNcuE6WYLAXeQDEkmlE';
  
  // 1. SIGNATURES LIST LOADER
  async function loadSignatures() {
    const listContainer = document.getElementById('signatures-list-container');
    if (!listContainer) return;

    try {
      const res = await fetch(`/casper-api/public/v1/firme/${slug}`, {
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json'
        }
      });

      if (!res.ok) {
        throw new Error();
      }

      const json = await res.json();
      const list = json.data || [];

      if (list.length === 0) {
        listContainer.innerHTML = '<div class="no-signatures">Nessuna firma apposta finora. Lascia la tua per primo.</div>';
        return;
      }

      // Populate list
      listContainer.innerHTML = '';
      list.forEach((item) => {
        const row = document.createElement('div');
        row.className = 'signature-item';

        const nameEl = document.createElement('span');
        nameEl.className = 'signature-name';
        nameEl.textContent = item.nominativo;

        row.appendChild(nameEl);

        if (item.firma_base64) {
          const wrapper = document.createElement('div');
          wrapper.className = 'signature-img-wrapper';
          const img = document.createElement('img');
          img.className = 'signature-img';
          img.src = item.firma_base64;
          img.alt = `Firma calligrafica di ${item.nominativo}`;
          wrapper.appendChild(img);
          row.appendChild(wrapper);
        } else {
          // If no image, show a placeholder or date
          const dateEl = document.createElement('span');
          dateEl.className = 'signature-date-only';
          dateEl.textContent = 'Presenza registrata';
          row.appendChild(dateEl);
        }

        listContainer.appendChild(row);
      });
    } catch (err) {
      listContainer.innerHTML = '<div class="no-signatures">Impossibile caricare le firme. Riprova più tardi.</div>';
    }
  }

  // Load signatures on mount
  document.addEventListener('DOMContentLoaded', () => {
    loadSignatures();
  });

  // 2. CANVAS DRAWING IMPLEMENTATION
  const canvas = document.getElementById('signature-canvas');
  const clearBtn = document.getElementById('canvas-clear');
  
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let isDrawing = false;
    let lastX = 0;
    let lastY = 0;

    // Set line appearance
    ctx.strokeStyle = '#1a1f2e'; // Elegant dark blue ink
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.lineWidth = 2.5;

    // Helper to get touch/mouse coordinates relative to canvas
    function getCoords(e) {
      const rect = canvas.getBoundingClientRect();
      // Account for canvas pixel scale versus layout size
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;

      let clientX, clientY;

      if (e.touches && e.touches.length > 0) {
        clientX = e.touches[0].clientX;
        clientY = e.touches[0].clientY;
      } else {
        clientX = e.clientX;
        clientY = e.clientY;
      }

      return {
        x: (clientX - rect.left) * scaleX,
        y: (clientY - rect.top) * scaleY
      };
    }

    function startDrawing(e) {
      isDrawing = true;
      const coords = getCoords(e);
      lastX = coords.x;
      lastY = coords.y;
      
      // Prevent default scrolling when drawing on touch screens
      if (e.cancelable) e.preventDefault();
    }

    function draw(e) {
      if (!isDrawing) return;
      const coords = getCoords(e);

      ctx.beginPath();
      ctx.moveTo(lastX, lastY);
      ctx.lineTo(coords.x, coords.y);
      ctx.stroke();

      lastX = coords.x;
      lastY = coords.y;

      if (e.cancelable) e.preventDefault();
    }

    function stopDrawing() {
      isDrawing = false;
    }

    // Mouse Listeners
    canvas.addEventListener('mousedown', startDrawing);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDrawing);
    canvas.addEventListener('mouseleave', stopDrawing);

    // Touch Listeners
    canvas.addEventListener('touchstart', startDrawing, { passive: false });
    canvas.addEventListener('touchmove', draw, { passive: false });
    canvas.addEventListener('touchend', stopDrawing);

    // Clear Canvas Action
    clearBtn?.addEventListener('click', () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
    });
  }

  // Helper function to check if canvas is blank
  function isCanvasBlank(canvasEl) {
    const blank = document.createElement('canvas');
    blank.width = canvasEl.width;
    blank.height = canvasEl.height;
    return canvasEl.toDataURL() === blank.toDataURL();
  }

  // 3. SUBMIT CONDOLENCE ACTION
  const cordoglioForm = document.getElementById('cordoglio-form');
  const cordoglioStatus = document.getElementById('cordoglio-status');
  const cordoglioBtn = document.getElementById('cordoglio-submit-btn');

  cordoglioForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!cordoglioBtn || !cordoglioStatus) return;

    // Show loading state
    cordoglioBtn.disabled = true;
    const originalText = cordoglioBtn.innerHTML;
    cordoglioBtn.innerHTML = '<span class="spinner-inline"></span> Invio in corso...';
    
    cordoglioStatus.className = 'form-status status-info';
    cordoglioStatus.style.display = 'block';
    cordoglioStatus.textContent = 'Invio del messaggio alla famiglia in corso...';

    const formData = new FormData(cordoglioForm);
    const payload = {
      slug: slug,
      nome: formData.get('nome'),
      telefono: formData.get('telefono'),
      mail: formData.get('mail') || null,
      testo: formData.get('testo'),
      visibile: false, // Private cordoglio by default
      provenienza: 1   // 1 indicates from website
    };

    try {
      const response = await fetch('/casper-api/public/v1/cordogli', {
        method: 'POST',
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.message || 'Errore di connessione al server.');
      }

      cordoglioStatus.className = 'form-status status-success';
      cordoglioStatus.textContent = 'Il tuo messaggio di cordoglio è stato inviato privatamente alla famiglia con successo.';
      
      // Clear inputs
      cordoglioForm.reset();
    } catch (err) {
      cordoglioStatus.className = 'form-status status-error';
      cordoglioStatus.textContent = err.message || 'Si è verificato un errore durante l\'invio. Verifica i dati o riprova più tardi.';
    } finally {
      cordoglioBtn.disabled = false;
      cordoglioBtn.innerHTML = originalText;
    }
  });

  // 4. SUBMIT SIGNATURE ACTION
  const signatureForm = document.getElementById('signature-form');
  const signatureStatus = document.getElementById('signature-status');
  const signatureBtn = document.getElementById('signature-submit-btn');

  signatureForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!signatureBtn || !signatureStatus || !canvas) return;

    // Validate canvas is signed
    const isSigned = !isCanvasBlank(canvas);
    if (!isSigned) {
      signatureStatus.className = 'form-status status-error';
      signatureStatus.style.display = 'block';
      signatureStatus.textContent = 'Errore: Per favore, apponi il tuo tratto di firma nel riquadro prima di inviare.';
      return;
    }

    // Show loading
    signatureBtn.disabled = true;
    const originalText = signatureBtn.innerHTML;
    signatureBtn.innerHTML = '<span class="spinner-inline"></span> Registrazione in corso...';
    
    signatureStatus.className = 'form-status status-info';
    signatureStatus.style.display = 'block';
    signatureStatus.textContent = 'Salvataggio della firma in corso...';

    const formData = new FormData(signatureForm);
    const signatureBase64 = canvas.toDataURL('image/png');

    const payload = {
      slug: slug,
      nominativo: formData.get('nominativo'),
      firma_base64: signatureBase64
    };

    try {
      const response = await fetch('/casper-api/public/v1/firme', {
        method: 'POST',
        headers: {
          'X-API-Key': apiKey,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.message || 'Errore nel salvataggio della firma.');
      }

      signatureStatus.className = 'form-status status-success';
      signatureStatus.textContent = 'La tua firma è stata registrata con successo sul Libro delle Presenze.';

      // Reset form and canvas
      signatureForm.reset();
      const ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Reload signatures list dynamically
      loadSignatures();
    } catch (err) {
      signatureStatus.className = 'form-status status-error';
      signatureStatus.textContent = err.message || 'Si è verificato un errore nella registrazione della firma. Riprova più tardi.';
    } finally {
      signatureBtn.disabled = false;
      signatureBtn.innerHTML = originalText;
    }
  });
</script>
