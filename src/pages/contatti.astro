---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contatti — Onoranze Funebri FADI | Dasà (VV)"
  description="Contatta le Onoranze Funebri FADI. Via Provinciale 25, 89832 Dasà (VV). Tel. 0963 353321 — Reperibilità H24. Email: servizifadi@gmail.com"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label">Reperibilità 24 ore su 24</p>
      <h1 class="page-hero-title">Contatti</h1>
      <div class="divider"></div>
      <p class="page-hero-sub">
        Saremo al tuo fianco con delicatezza e professionalità.
        Non esitare a contattarci in qualsiasi momento.
      </p>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="section" id="contatti-info">
    <div class="container contatti-grid">

      <!-- Left: info -->
      <div class="contatti-info">
        <div class="info-block">
          <h2 class="info-block-title">Recapiti telefonici</h2>
          <p class="info-block-sub">
            L'Agenzia Funebre FADI eroga i propri servizi presso cliniche, ospedali, case di cura e
            abitazioni. Disponibilità continua h24, giorno e notte, anche nei festivi.
          </p>

          <div class="phone-list">
            <a href="tel:+390963353321" class="phone-item-full" id="contatti-tel-1">
              <div class="phone-icon-wrap" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
              </div>
              <div>
                <span class="pn">0963 353321</span>
                <span class="pl">Linea principale</span>
              </div>
            </a>
            <a href="tel:+393286731960" class="phone-item-full" id="contatti-tel-2">
              <div class="phone-icon-wrap" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
              </div>
              <div>
                <span class="pn">328 6731960</span>
                <span class="pl">Raffaele</span>
              </div>
            </a>
            <a href="tel:+393398970915" class="phone-item-full" id="contatti-tel-3">
              <div class="phone-icon-wrap" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
              </div>
              <div>
                <span class="pn">339 8970915</span>
                <span class="pl">Maria</span>
              </div>
            </a>
          </div>
        </div>

        <div class="info-block">
          <h2 class="info-block-title">Email e PEC</h2>
          <div class="email-list">
            <a href="mailto:servizifadi@gmail.com" class="email-item" id="contatti-email">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
              <div>
                <span class="em">servizifadi@gmail.com</span>
                <span class="et">Email ordinaria</span>
              </div>
            </a>
            <a href="mailto:fadiescaturchio@pec.it" class="email-item" id="contatti-pec">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <div>
                <span class="em">fadiescaturchio@pec.it</span>
                <span class="et">PEC — Posta Elettronica Certificata</span>
              </div>
            </a>
          </div>
        </div>

        <div class="info-block">
          <h2 class="info-block-title">Social</h2>
          <a
            href="https://www.facebook.com/Agenzia-Funebre-FADI-Scaturchio-719911154726041/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            id="contatti-facebook"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            Seguici su Facebook
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15,3 21,3 21,9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: address + map -->
      <div class="contatti-map-col">
        <div class="address-card">
          <div class="address-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            <h2>Dove siamo</h2>
          </div>
          <address>
            <strong>Onoranze Funebri FADI</strong><br />
            Via Provinciale, 25<br />
            89832 Dasà (VV)
          </address>
          <a
            href="https://goo.gl/maps/mpVeEUgmVgMkyFUWA"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-outline map-btn"
            id="contatti-mappa-link"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            Apri in Google Maps
          </a>
        </div>

        <!-- Map iframe -->
        <div class="map-wrapper">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3040.123!2d16.2083!3d38.5208!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x13147c7b7a000001%3A0x1!2sDas%C3%A0%2C%2089832%20VV!5e0!3m2!1sit!2sit!4v1234567890"
            width="100%"
            height="280"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mappa Onoranze Funebri FADI — Dasà (VV)"
          ></iframe>
        </div>

        <!-- H24 card -->
        <div class="h24-card">
          <div class="h24-dot" aria-hidden="true"></div>
          <div>
            <strong>Reperibilità H24 · 365 giorni</strong>
            <p>Siamo disponibili in qualsiasi momento, giorno e notte, anche nei festivi.</p>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background-image: 
      linear-gradient(to bottom, rgba(20, 18, 16, 0.65) 0%, rgba(20, 18, 16, 0.92) 100%),
      url('../img/sfondi/contatti.jpg');
    background-size: cover;
    background-position: center;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .page-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-top: 0.75rem;
    color: #ffffff; /* Bright white title */
  }
  .page-hero-sub {
    color: #e5e1db; /* Readable light warm-grey subtitle */
    font-size: 1.05rem;
    max-width: 520px;
    margin-top: 1rem;
    line-height: 1.75;
  }
  .page-hero .section-label {
    color: var(--gold-light) !important;
  }
  .page-hero .divider {
    background: var(--gold) !important;
  }
  /* Grid */
  .contatti-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: start;
  }
  /* Info blocks */
  .info-block {
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .info-block:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .info-block-title {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .info-block-sub {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 500px;
  }
  /* Phones */
  .phone-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .phone-item-full {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(44, 38, 32, 0.02);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .phone-item-full:hover {
    border-color: var(--gold);
    transform: translateX(4px);
    box-shadow: 0 6px 24px rgba(184, 150, 110, 0.08);
  }
  .phone-icon-wrap {
    width: 40px;
    height: 40px;
    background: var(--gold-dim);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
  }
  .pn {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }
  .pl {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  /* Emails */
  .email-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .email-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(44, 38, 32, 0.02);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .email-item:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(184, 150, 110, 0.08);
  }
  .email-item svg { color: var(--gold); flex-shrink: 0; }
  .em {
    display: block;
    font-size: 0.92rem;
    color: var(--text);
    font-weight: 400;
  }
  .et {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  /* Social */
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    color: var(--text);
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(44, 38, 32, 0.02);
    transition: border-color var(--transition), color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .social-link svg:first-child { color: var(--gold); }
  .social-link svg:last-child { color: var(--text-muted); }
  .social-link:hover { border-color: var(--gold); color: var(--gold-light); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(184, 150, 110, 0.08); }
  /* Map col */
  .contatti-map-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 90px;
  }
  .address-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(44, 38, 32, 0.02);
  }
  .address-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
    color: var(--gold);
  }
  .address-header h2 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--text);
  }
  address {
    font-style: normal;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  address strong { color: var(--text); }
  .map-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
  }
  .map-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    line-height: 0;
  }
  /* H24 card */
  .h24-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(184,150,110,0.06);
    border: 1px solid rgba(184,150,110,0.25);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    box-shadow: 0 4px 20px rgba(184, 150, 110, 0.04);
  }
  .h24-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74,222,128,0.5);
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }
  .h24-card strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .h24-card p {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @media (max-width: 900px) {
    .contatti-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .contatti-map-col { position: static; }
  }
</style>
