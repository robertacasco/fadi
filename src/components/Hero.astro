---
interface Props {
  tagline?: string;
  sub?: string;
}

const {
  tagline = 'Da oltre 30 anni al tuo fianco nel momento più difficile',
  sub = 'Professionalità, discrezione e rispetto. Disponibili 24 ore su 24, 365 giorni all\'anno.',
} = Astro.props;
---

<section class="hero" aria-label="Hero principale">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="container hero-content">
    <!-- Emblem -->
    <div class="hero-emblem" aria-hidden="true">
      <div class="emblem-ring">
        <span class="emblem-cross">✝</span>
      </div>
    </div>

    <p class="hero-label">Onoranze Funebri FADI · Dal 1991</p>
    <h1 class="hero-title">{tagline}</h1>
    <div class="hero-divider" aria-hidden="true"></div>
    <p class="hero-sub">{sub}</p>

    <!-- Phone numbers -->
    <div class="hero-phones" role="list" aria-label="Numeri di telefono">
      <a href="tel:+390963353321" class="phone-item" role="listitem">
        <span class="phone-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
        </span>
        <div>
          <span class="phone-number">0963 353321</span>
          <span class="phone-label">Linea principale</span>
        </div>
      </a>
      <a href="tel:+393286731960" class="phone-item" role="listitem">
        <span class="phone-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
        </span>
        <div>
          <span class="phone-number">328 6731960</span>
          <span class="phone-label">Raffaele</span>
        </div>
      </a>
      <a href="tel:+393398970915" class="phone-item" role="listitem">
        <span class="phone-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
        </span>
        <div>
          <span class="phone-number">339 8970915</span>
          <span class="phone-label">Maria</span>
        </div>
      </a>
    </div>

    <!-- CTA buttons -->
    <div class="hero-actions">
      <a href="/contatti" class="btn btn-gold" id="hero-cta-contatti">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
        Contattaci
      </a>
      <a href="/annunci-funebri/" class="btn btn-outline" id="hero-cta-annunci">
        Annunci Funebri
      </a>
    </div>

    <!-- H24 badge -->
    <div class="hero-badge" aria-label="Servizio attivo 24 ore su 24">
      <span class="badge-dot" aria-hidden="true"></span>
      Reperibilità H24 · Anche nei festivi
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - 85px); /* Adjusted for new header height */
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Background */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: 
      linear-gradient(to bottom, rgba(20, 18, 16, 0.65) 0%, rgba(20, 18, 16, 0.92) 100%),
      url('../img/sfondi/home.jpg');
    background-size: cover;
    background-position: center;
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  /* Emblem */
  .hero-emblem {
    margin-bottom: 2rem;
  }

  .emblem-ring {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1px solid var(--gold-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(184,150,110,0.08);
    position: relative;
  }

  .emblem-ring::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(184,150,110,0.15);
  }

  .emblem-cross {
    font-size: 1.8rem;
    color: var(--gold);
    opacity: 0.95;
  }

  /* Text */
  .hero-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.2;
    max-width: 780px;
    font-style: italic;
    color: #ffffff; /* Bright white title */
    margin-bottom: 0;
  }

  .hero-divider {
    width: 48px;
    height: 2px;
    background: var(--gold);
    margin: 2rem auto;
    opacity: 0.95;
  }

  .hero-sub {
    color: #e5e1db; /* Bright readable warm-grey subtitle */
    font-size: 1.05rem;
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }

  /* Phones */
  .hero-phones {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .phone-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.05); /* Semitransparent glass backing */
    border: 1px solid rgba(184, 150, 110, 0.35); /* Elegant gold border */
    border-radius: var(--radius);
    padding: 0.8rem 1.25rem;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: border-color var(--transition), background var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .phone-item:hover {
    border-color: var(--gold);
    background: rgba(184, 150, 110, 0.15);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(184, 150, 110, 0.22);
  }

  .phone-icon {
    color: var(--gold);
    display: flex;
    align-items: center;
  }

  .phone-number {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
  }

  .phone-label {
    display: block;
    font-size: 0.72rem;
    color: #d5cec6;
    letter-spacing: 0.05em;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .hero-actions .btn-outline {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .hero-actions .btn-outline:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #ffffff;
    color: #ffffff;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: #e5e1db;
    letter-spacing: 0.05em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px rgba(74, 222, 128, 0.6);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollDown 2s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% { transform: scaleY(0); transform-origin: top; opacity: 0; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(1); transform-origin: bottom; opacity: 0; }
  }

  @media (max-width: 600px) {
    .hero-phones {
      flex-direction: column;
      width: 100%;
    }

    .phone-item {
      width: 100%;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
