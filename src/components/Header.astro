---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/fioreria', label: 'Fioreria' },
  { href: '/servizi', label: 'Servizi' },
  { href: '/annunci-funebri/', label: 'Annunci Funebri' },
  { href: '/contatti', label: 'Contatti' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">

    <!-- Logo / Brand -->
    <a href="/" class="brand" aria-label="Onoranze Funebri FADI — Home">
      <span class="brand-cross" aria-hidden="true">✝</span>
      <div class="brand-text">
        <span class="brand-name">FADI</span>
        <span class="brand-sub">Onoranze Funebri</span>
      </div>
    </a>

    <!-- Navigation Desktop -->
    <nav class="nav-desktop" aria-label="Navigazione principale">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href || currentPath === link.href + '/' ? 'active' : ''} ${link.href === '/annunci-funebri/' ? 'nav-link--announcements' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA tel -->
    <a href="tel:+390963353321" class="header-tel" aria-label="Chiama FADI">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/>
      </svg>
      0963 353321
    </a>

    <!-- Hamburger mobile -->
    <button class="hamburger" id="hamburger-btn" aria-label="Apri menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Mobile Menu -->
  <nav class="nav-mobile" id="mobile-menu" aria-label="Menu mobile" aria-hidden="true">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`nav-mobile-link ${link.href === '/annunci-funebri/' ? 'nav-mobile-link--announcements' : ''}`}
      >
        {link.label}
      </a>
    ))}
    <a href="tel:+390963353321" class="nav-mobile-tel">
      📞 0963 353321
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26, 31, 46, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 70px;
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-cross {
    font-size: 1.4rem;
    color: var(--gold);
    line-height: 1;
    opacity: 0.9;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--text);
  }

  .brand-sub {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 700;
  }

  /* Nav desktop */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    transition: color var(--transition), background var(--transition);
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--bg-card);
  }

  .nav-link.active {
    color: var(--gold);
  }

  .nav-link--announcements {
    color: var(--gold);
    border: 1px solid var(--gold-dim);
  }

  .nav-link--announcements:hover {
    background: var(--gold-dim);
    color: var(--gold-light);
  }

  /* CTA tel */
  .header-tel {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--bg);
    background: var(--gold);
    padding: 0.45rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background var(--transition);
  }

  .header-tel:hover {
    background: var(--gold-light);
    color: var(--bg);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Mobile menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.25rem;
  }

  .nav-mobile.open {
    display: flex;
  }

  .nav-mobile-link {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: color var(--transition);
  }

  .nav-mobile-link:hover {
    color: var(--text);
  }

  .nav-mobile-link--announcements {
    color: var(--gold);
  }

  .nav-mobile-tel {
    margin-top: 1rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--gold);
    text-decoration: none;
    padding: 0.5rem 0;
  }

  @media (max-width: 900px) {
    .nav-desktop,
    .header-tel {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });
</script>
