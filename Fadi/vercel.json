{
  "cleanUrls": false,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/necrologi",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/necrologi/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/annuncio",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/annuncio/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/casper/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/annunci-funebri",
      "destination": "/necrologi/",
      "permanent": true
    },
    {
      "source": "/annunci-funebri/",
      "destination": "/necrologi/",
      "permanent": true
    },
    {
      "source": "/annunci-funebri/:path*",
      "destination": "/necrologi/",
      "permanent": true
    },
    {
      "source": "/annuncio",
      "destination": "/necrologi/",
      "permanent": false
    },
    {
      "source": "/annuncio/",
      "destination": "/necrologi/",
      "permanent": false
    },
    {
      "source": "/annuncio/:paese/:slug",
      "destination": "/necrologi/:slug/",
      "permanent": false
    },
    {
      "source": "/annuncio/:paese/:slug/",
      "destination": "/necrologi/:slug/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/diretta", "destination": "https://testaf.lab.cas-per.it/diretta/" },
    { "source": "/diretta/", "destination": "https://testaf.lab.cas-per.it/diretta/" },
    { "source": "/diretta/:path*", "destination": "https://testaf.lab.cas-per.it/diretta/:path*" },
    { "source": "/wp-content/:path*", "destination": "https://testaf.lab.cas-per.it/wp-content/:path*" },
    { "source": "/wp-includes/:path*", "destination": "https://testaf.lab.cas-per.it/wp-includes/:path*" }
  ]
}
