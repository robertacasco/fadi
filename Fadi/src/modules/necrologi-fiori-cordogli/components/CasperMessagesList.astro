---
import type { AnnuncioData, CordoglioData, FotoCordoglioAlbum, FotoCordoglioData } from '../types';

interface Props {
  item: AnnuncioData;
  cordogli?: CordoglioData[];
  fotoCordogli?: FotoCordoglioAlbum[];
}

const { item, cordogli = [], fotoCordogli = [] } = Astro.props;
const defunto = item.defunto || {};
const nomeCompleto = item.nominativo || `${defunto.nome || ''} ${defunto.cognome || ''}`.trim();

function isPublicValue(value: unknown): boolean {
  return value !== false && value !== 0 && value !== '0' && value !== 'false';
}

function formatDate(str?: string): string {
  if (!str) return '';
  const date = new Date(str);
  if (Number.isNaN(date.getTime())) return '';
  return date.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}

function getMessageName(message: CordoglioData): string {
  return message.utente?.nome || message.mittente || 'Anonimo';
}

function getMessageDate(message: CordoglioData): string {
  return message.created_at || message.data_creazione || '';
}

function getMessageText(message: CordoglioData): string {
  return message.testo || '';
}

function getMessageLines(message: CordoglioData): string[] {
  return getMessageText(message).split(/\r?\n/);
}

function getPhotoUrl(photo: FotoCordoglioData): string {
  return photo.url || photo.foto_url || photo.image_url || photo.immagine_url || photo.src || '';
}

function getPhotoCaption(photo: FotoCordoglioData): string {
  return photo.didascalia || photo.caption || photo.descrizione || 'Foto ricordo';
}

const visibleMessages = cordogli.filter((message) => isPublicValue(message.visibile));
const visiblePhotos = fotoCordogli
  .flatMap((album) => album.foto || album.photos || [])
  .filter((photo) => getPhotoUrl(photo) && isPublicValue(photo.approvata) && isPublicValue(photo.visibile));

const hasMessages = visibleMessages.length > 0;
const hasPhotos = visiblePhotos.length > 0;
---

<section class="section messaggi-ricevuti-section" id="messaggi-ricevuti">
  <div class="container">
    <div class="text-center section-header">
      <span class="section-label">In memoria</span>
      <h2 class="section-title">Messaggi e foto</h2>
      <div class="divider mx-auto"></div>
      <p class="section-text" style="margin: 0 auto;">
        I pensieri di affetto e le parole di cordoglio lasciati dalla comunità.
      </p>
    </div>

    <div id="foto-section" class="foto-carousel-wrap" style={hasPhotos ? 'display:block;' : 'display:none;'}>
      <div class="foto-carousel-track" id="foto-grid" data-has-photos={hasPhotos ? 'true' : 'false'}>
        {visiblePhotos.map((photo) => (
          <div class="foto-thumb" title={getPhotoCaption(photo)}>
            <img
              src={getPhotoUrl(photo)}
              alt={getPhotoCaption(photo)}
              loading="lazy"
              onerror="this.closest('.foto-thumb').remove()"
            />
          </div>
        ))}
      </div>
    </div>

    <div id="msg-loading" class="msg-loading-wrap" style={hasMessages ? 'display:none;' : ''}>
      <div class="msg-skeleton"></div>
      <div class="msg-skeleton"></div>
      <div class="msg-skeleton"></div>
    </div>

    <div
      id="msg-list"
      class="msg-cards-grid"
      data-has-messages={hasMessages ? 'true' : 'false'}
      style={hasMessages ? 'display:block;' : 'display:none;'}
    >
      {visibleMessages.map((message, index) => (
        <div class="msg-card" style={`animation-delay:${index * 0.07}s`}>
          <div class="msg-card-top">
            <div>
              <div class="msg-name">{getMessageName(message)}</div>
              {formatDate(getMessageDate(message)) && <div class="msg-date">{formatDate(getMessageDate(message))}</div>}
            </div>
          </div>
          <div class="msg-text">
            {getMessageLines(message).map((line, lineIndex) => (
              <>{lineIndex > 0 && <br />}{line}</>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div id="msg-empty" class="msg-empty-state" style={hasMessages ? 'display:none;' : 'display:flex;'}>
      <p>Se desideri inviare un messaggio o una foto in ricordo di <strong>{nomeCompleto}</strong> <a href="#cordoglio" class="gold-link">clicca qui</a>.</p>
    </div>
  </div>
</section>
