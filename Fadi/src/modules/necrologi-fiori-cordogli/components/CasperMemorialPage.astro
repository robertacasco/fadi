  // 10. PRESET MODAL ACTIONS
  const openPresets = document.getElementById('open-presets-btn');
  const closePresets = document.getElementById('close-presets-btn');
  const presetsModal = document.getElementById('presets-modal');
  const presetButtons = document.querySelectorAll('.preset-option-btn');
