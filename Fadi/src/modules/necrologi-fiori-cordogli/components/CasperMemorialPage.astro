---
import type { AnnuncioData, CordoglioData, FioreData, FotoCordoglioAlbum } from '../types';
import CasperMemorialDetails from './CasperMemorialDetails.astro';
import CasperMessagesList from './CasperMessagesList.astro';
import CasperCondolenceForms from './CasperCondolenceForms.astro';

interface Props {
  item: AnnuncioData;
  apiKey: string;
  slug: string;
  fiori?: FioreData[];
  cordogli?: CordoglioData[];
  fotoCordogli?: FotoCordoglioAlbum[];
}

const { item, apiKey, slug, fiori = [], cordogli = [], fotoCordogli = [] } = Astro.props;
const defunto = item.defunto || {};
const nomeCompleto = item.nominativo || `${defunto.nome || ''} ${defunto.cognome || ''}`.trim();
---

<CasperMemorialDetails item={item} />
<CasperMessagesList item={item} cordogli={cordogli} fotoCordogli={fotoCordogli} />
<CasperCondolenceForms item={item} fiori={fiori} />
<style is:global>
  /* Memorial layout details */
  .memorial-header-section {
    background-color: var(--bg-soft);
    border-bottom: 1px solid var(--border);
    padding: 5rem 0;
  }

  .header-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .memorial-photo-wrapper {
    display: flex;
    justify-content: center;
  }

  .memorial-frame {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 3.2 / 4;
    border-radius: var(--radius);
    background-color: #ffffff;
    box-shadow: 0 10px 40px rgba(44, 38, 32, 0.08);
    overflow: hidden;
  }

  .memorial-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .memorial-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-soft) 0%, rgba(184, 150, 110, 0.03) 100%);
  }

  .placeholder-cross-lg {
    font-size: 5rem;
    color: var(--gold);
    opacity: 0.3;
    font-family: var(--font-serif);
  }

  .frame-gold-border {
    position: absolute;
    inset: 16px;
    border: 1px solid rgba(184, 150, 110, 0.28);
    pointer-events: none;
  }

  /* Info on right */
  .memorial-primary-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .emblem {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.75rem;
    opacity: 0.9;
  }

  .annuncio-label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .deceased-name {
    font-size: clamp(2.25rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .dates-eta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .info-tag {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.6rem 1.25rem;
    box-shadow: 0 4px 12px rgba(44, 38, 32, 0.01);
  }

  .tag-title {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .tag-val {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 0.15rem;
  }

  .deceased-quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--text-muted);
    border-left: 2px solid var(--gold);
    padding-left: 1.25rem;
    margin: 0.5rem 0 2.25rem;
    line-height: 1.6;
    max-width: 680px;
  }

  .action-buttons-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .action-buttons-group .btn {
    padding: 0.9rem 2.2rem;
  }

  /* Ceremonies section */
  .ceremonies-section {
    background-color: var(--bg);
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .ceremonies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .ceremony-detail-card {
    display: flex;
    flex-direction: column;
    padding: 2.25rem 2rem;
    height: 100%;
    align-items: center;
    text-align: center;
    background-color: #ffffff;
  }

  .card-highlighted {
    border-color: var(--gold);
    background: linear-gradient(to bottom, #ffffff 0%, rgba(184, 150, 110, 0.02) 100%);
    box-shadow: 0 10px 30px rgba(184, 150, 110, 0.06);
  }

  .ceremony-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .ceremony-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    color: var(--gold);
  }

  .ceremony-header h3 {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .ceremony-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .time-block {
    display: flex;
    flex-direction: column;
    background-color: var(--bg-soft);
    padding: 0.75rem 1rem;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .time-date {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .time-hours {
    font-size: 0.85rem;
    color: var(--gold);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.15rem;
  }

  .address-block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .place-name {
    font-weight: 700;
    color: var(--text);
    font-size: 1rem;
  }

  .place-address {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .maps-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    transition: all var(--transition);
  }

  .maps-link:hover {
    color: var(--gold);
    border-color: var(--gold);
    background-color: var(--bg-soft);
  }

  .highlighted-link {
    background-color: var(--gold-dim);
    border-color: var(--gold);
    color: var(--gold);
  }

  .highlighted-link:hover {
    background-color: var(--gold);
    color: #1a1f2e;
  }

  /* Streaming info */
  .streaming-block {
    margin-top: 4.5rem;
  }

  .streaming-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem;
    position: relative;
    border-color: #4ade80; /* Elegant soft green border for live streaming activity */
    background: linear-gradient(to bottom, #ffffff 0%, rgba(74, 222, 128, 0.01) 100%);
  }

  .live-dot-pulse {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
    animation: livePulse 2s infinite;
  }

  @keyframes livePulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.5; }
  }

  .streaming-inner h3 {
    font-size: 1.45rem;
    margin-bottom: 0.5rem;
  }

  .streaming-inner p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .streaming-btn {
    border: none;
    background-color: #4ade80;
    color: #111827;
  }

  .streaming-btn:hover {
    background-color: #2ecc71;
    color: #111827;
    box-shadow: 0 6px 24px rgba(46, 204, 113, 0.25);
  }

  /* Interactive section split */
  .interactive-memorial-section {
    background-color: var(--bg-soft);
    border-top: 1px solid var(--border);
  }

  .interactive-grid {
    display: block;
    max-width: 820px;
    margin: 0 auto;
  }

  .interactive-card {
    padding: 3rem 2.5rem;
    background-color: #ffffff;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .card-title-header {
    margin-bottom: 2rem;
  }

  .card-title-header h3 {
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .card-title-header p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Forms general styling */
  .memorial-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .memorial-form label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
  }

  .memorial-form input, .memorial-form textarea {
    padding: 0.85rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    outline: none;
    transition: all var(--transition);
  }

  .memorial-form input:focus, .memorial-form textarea:focus {
    border-color: var(--gold);
    background-color: #ffffff;
    box-shadow: 0 4px 16px rgba(184, 150, 110, 0.08);
  }

  .btn-block {
    width: 100%;
    justify-content: center;
    padding: 1rem 0;
  }

  /* Feedback status */
  .form-status {
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-top: 0.5rem;
    display: none;
    font-weight: 500;
  }

  .status-success {
    display: block;
    background-color: rgba(46, 204, 113, 0.1);
    color: #27ae60;
    border: 1px solid rgba(46, 204, 113, 0.2);
  }

  .status-error {
    display: block;
    background-color: rgba(231, 76, 60, 0.1);
    color: #c0392b;
    border: 1px solid rgba(231, 76, 60, 0.2);
  }

  .status-info {
    display: block;
    background-color: var(--gold-dim);
    color: var(--gold);
    border: 1px solid var(--border);
  }

  /* Spinner */
  .spinner-inline {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: rotateSpinner 0.8s linear infinite;
    vertical-align: -2px;
    margin-right: 0.5rem;
  }

  @keyframes rotateSpinner {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (max-width: 900px) {
    .header-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .memorial-photo-wrapper {
      max-width: 260px;
      margin: 0 auto;
    }

    .memorial-primary-info {
      align-items: center;
    }

    .deceased-quote {
      text-align: center;
      border-left: none;
      border-top: 1px dashed var(--border);
      border-bottom: 1px dashed var(--border);
      padding: 1rem 0;
      margin: 1.5rem 0;
    }

    .dates-eta {
      justify-content: center;
    }

    .action-buttons-group {
      justify-content: center;
      width: 100%;
    }

    .action-buttons-group .btn {
      width: 100%;
      justify-content: center;
    }

    .interactive-card {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  /* Tabs for condolence types */
  .memorial-tabs {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 0.5rem !important;
    background-color: var(--bg-soft, #f8f6f2) !important;
    padding: 0.35rem !important;
    border-radius: 8px !important;
    margin-bottom: 2rem !important;
    border: 1px solid var(--border, #e5e0d8) !important;
  }

  .tab-btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 0.5rem !important;
    padding: 0.75rem 1.25rem !important;
    font-family: var(--font-sans), sans-serif !important;
    font-size: 0.88rem !important;
    font-weight: 700 !important;
    color: var(--text-muted, #70665C) !important;
    background: transparent !important;
    border: none !important;
    border-radius: 6px !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    box-shadow: none !important;
    outline: none !important;
    -webkit-appearance: none !important;
    appearance: none !important;
  }

  .tab-btn:hover {
    color: var(--text, #2C2620) !important;
    background-color: rgba(184, 150, 110, 0.04) !important;
  }

  .tab-btn.active {
    background-color: #ffffff !important;
    color: var(--gold, #b8966e) !important;
    box-shadow: 0 4px 12px rgba(44, 38, 32, 0.08) !important;
  }

  @media (max-width: 540px) {
    .memorial-tabs {
      grid-template-columns: 1fr !important;
      gap: 0.35rem !important;
      padding: 0.4rem !important;
    }
    .tab-btn {
      padding: 0.65rem 1rem !important;
      font-size: 0.85rem !important;
      width: 100% !important;
      justify-content: center !important;
    }
  }

  /* Photo upload dropzone */
  .photo-upload-zone {
    border: 2px dashed rgba(184, 150, 110, 0.4);
    background-color: var(--bg);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: all var(--transition);
  }

  .photo-upload-zone:hover, .photo-upload-zone.dragover {
    border-color: var(--gold);
    background-color: rgba(184, 150, 110, 0.04);
  }

  .upload-zone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .upload-icon {
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .upload-title {
    font-size: 0.9rem;
    color: var(--text);
  }

  .upload-title strong {
    color: var(--gold);
  }

  .upload-subtitle {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Photo preview grid */
  .photo-preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .photo-preview-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .photo-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-remove-btn {
    position: absolute;
    top: 4px;
    right: 4px;
    background: rgba(231, 76, 60, 0.9);
    color: #ffffff;
    border: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    font-size: 0.75rem;
    line-height: 20px;
    text-align: center;
    cursor: pointer;
    transition: background-color var(--transition);
    padding: 0;
  }

  .photo-remove-btn:hover {
    background: #c0392b;
  }

  /* Manifesto Thumbnail Hover & Interaction */
  .manifesto-thumbnail-card:hover {
    transform: translateY(-4px);
    border-color: var(--gold) !important;
    box-shadow: 0 8px 24px rgba(184, 150, 110, 0.15) !important;
  }
  .manifesto-thumbnail-card:hover .manifesto-overlay {
    opacity: 1 !important;
  }

  /* Manifesto Modal Styles */
  .manifesto-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: rgba(26, 31, 46, 0.85);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .manifesto-modal-overlay.active {
    display: flex !important;
    opacity: 1 !important;
  }
  .manifesto-modal-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
    background: #ffffff;
    padding: 0.75rem;
    border-radius: var(--radius);
    border: 2px solid var(--gold);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    transform: scale(0.9);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .manifesto-modal-overlay.active .manifesto-modal-content {
    transform: scale(1) !important;
  }
  .manifesto-modal-content img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: calc(var(--radius) - 4px);
  }
  .manifesto-modal-caption {
    text-align: center;
    margin-top: 0.75rem;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }
  .close-manifesto-btn {
    position: absolute;
    top: -1.75rem;
    right: -1.75rem;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3) !important;
    background: rgba(0, 0, 0, 0.5) !important;
    color: #ffffff !important;
    font-size: 1.5rem !important;
    line-height: 2rem;
    text-align: center;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
  }
  .close-manifesto-btn:hover {
    background-color: var(--gold) !important;
    border-color: var(--gold) !important;
    transform: rotate(90deg);
  }

  /* --- Burgundy theme and form enhancements --- */
  :root {
    --burgundy: #6b1426;
  }

  .condolence-intro-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px dashed var(--border);
    padding-bottom: 1.5rem;
  }

  .condolence-main-title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--burgundy);
    margin-bottom: 0.5rem;
  }

  .condolence-intro-text {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.6;
    margin: 0;
  }

  .condolence-intro-text strong {
    font-weight: 700;
  }

  .condolence-intro-text.text-light {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .burgundy-link {
    color: var(--burgundy) !important;
    font-weight: 700;
    text-decoration: underline !important;
    transition: color var(--transition);
  }

  .burgundy-link:hover {
    color: var(--gold) !important;
  }

  .btn-burgundy {
    background-color: var(--burgundy);
    color: #ffffff !important;
    font-family: var(--font-sans);
    font-weight: 700;
    border: none;
    letter-spacing: 0.05em;
    transition: all var(--transition);
  }

  .btn-burgundy:hover {
    background-color: #550f1d;
    box-shadow: 0 4px 12px rgba(107, 20, 38, 0.2);
  }

  .btn-outline-gold {
    background-color: transparent;
    color: var(--gold) !important;
    font-family: var(--font-sans);
    font-weight: 700;
    border: 1.5px solid var(--gold) !important;
    letter-spacing: 0.05em;
    transition: all var(--transition);
  }

  .btn-outline-gold:hover {
    background-color: var(--gold);
    color: #1a1f2e !important;
    box-shadow: 0 4px 12px rgba(184, 150, 110, 0.25);
  }

  .address-recapito-block {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    background-color: var(--bg-soft);
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    text-align: left;
  }

  .address-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  /* Visually hidden helper for clean semantic markup */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ==========================================
     FIORI / FLOWER E-COMMERCE SECTION
     ========================================== */
  .fiori-section {
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .fiori-intro-text {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 680px;
    margin: 1.25rem auto 0.5rem;
  }

  .fiori-disclaimer {
    font-size: 0.78rem;
    color: var(--text-muted);
    opacity: 0.75;
    max-width: 600px;
    margin: 0.5rem auto 0;
    font-style: italic;
  }

  .fiori-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
