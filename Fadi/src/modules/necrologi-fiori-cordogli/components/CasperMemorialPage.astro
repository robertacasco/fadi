  // ============================================
  // MESSAGGI & FOTO RICEVUTI
  // ============================================
  (async () => {
    const msgLoading  = document.getElementById('msg-loading');
    const msgList     = document.getElementById('msg-list');
    const msgEmpty    = document.getElementById('msg-empty');
    const fotoSection = document.getElementById('foto-section');
    const fotoGrid    = document.getElementById('foto-grid');
    const hasServerMessages = msgList?.dataset.hasMessages === 'true';

    if (hasServerMessages && msgLoading) {
      msgLoading.style.display = 'none';
    }

    function formatDate(str) {
      if (!str) return '';
      try {
        const d = new Date(str);
        if (isNaN(d.getTime())) return '';
        return d.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
      } catch { return ''; }
    }

    function getApiArray(json, keys) {
      if (Array.isArray(json)) return json;
      if (Array.isArray(json?.data)) return json.data;
      for (const key of keys) {
        if (Array.isArray(json?.data?.[key])) return json.data[key];
        if (Array.isArray(json?.[key])) return json[key];
      }
      return [];
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function isPublicValue(value) {
      return value !== false && value !== 0 && value !== '0' && value !== 'false';
    }

    function makeCard(nome, testo, data, delay = 0) {
      const dt   = formatDate(data);
      const safeName = escapeHtml(nome || 'Anonimo');
      const safeText = escapeHtml(testo).replace(/\r?\n/g, '<br>');
      return `
        <div class="msg-card" style="animation-delay:${delay}s">
          <div class="msg-card-top">
            <div>
              <div class="msg-name">${safeName}</div>
              ${dt ? `<div class="msg-date">${dt}</div>` : ''}
            </div>
          </div>
          <div class="msg-text">${safeText}</div>
        </div>`;
    }

    function renderMessages(cordogli) {
      if (msgLoading) msgLoading.style.display = 'none';
      const visible = cordogli.filter(m => isPublicValue(m.visibile));
      if (visible.length === 0) {
        if (msgEmpty) msgEmpty.style.display = 'flex';
        return;
      }
      const html = visible.map((m, i) =>
        makeCard(m.utente?.nome || m.mittente || 'Anonimo', m.testo, m.created_at, i * 0.07)
      ).join('');
      if (msgList) { msgList.innerHTML = html; msgList.style.display = 'block'; }
    }

    function renderFotos(albums) {
      // Flatten all public photos from all albums.
      const fotos = albums
        .flatMap(a => a.foto || a.photos || [])
        .filter(f => f.url && isPublicValue(f.approvata) && isPublicValue(f.visibile));
      if (fotos.length === 0) return;
      const html = fotos.map(f => {
        const caption = escapeHtml(f.didascalia || 'Foto ricordo');
        const url = escapeHtml(f.url);
        return `
        <div class="foto-thumb" title="${caption}">
          <img src="${url}" alt="${caption}" loading="lazy"
               onerror="this.closest('.foto-thumb').remove()">
        </div>`;
      }).join('');
      if (fotoGrid)    fotoGrid.innerHTML = html;
      if (fotoSection) fotoSection.style.display = 'block';
    }

    // Live-add a new public message after submit
    window._sidebarAddMessage = function(nome, testo) {
      if (!msgList) return;
      if (msgEmpty) msgEmpty.style.display = 'none';
      const wrapper = document.createElement('div');
      wrapper.innerHTML = makeCard(nome, testo, new Date().toISOString(), 0);
      msgList.prepend(wrapper.firstElementChild);
      msgList.style.display = 'block';
    };

    try {
      const res = await fetch(`/casper-api/public/v1/annunci/${annuncioId}/cordogli/`, {
        headers: { 'X-API-Key': apiKey, 'Accept': 'application/json' }
      });

      if (res.ok) {
        const json = await res.json();
        renderMessages(getApiArray(json, ['cordogli', 'messaggi', 'messages']));
      } else if (!hasServerMessages) {
        renderMessages([]);
      }
    } catch {
      if (!hasServerMessages) renderMessages([]);
    }

    try {
      const resF = await fetch(`/casper-api/public/v1/annunci/${annuncioId}/fotocordogli/`, {
        headers: { 'X-API-Key': apiKey, 'Accept': 'application/json' }
      });
      if (resF.ok) {
        const jsonF = await resF.json();
        renderFotos(getApiArray(jsonF, ['albums', 'album', 'fotocordogli']));
      }
    } catch { /* foto-cordogli non disponibili */ }
  })();

  // ============================================
  // FIORI / FLOWER ORDER — INLINE FORM
  // ============================================
  const fioriFormWrap    = document.getElementById('fiori-inline-form-wrap');
  const fioriOrderForm   = document.getElementById('fiori-order-form');
  const fioriOrderStatus = document.getElementById('fiori-status') || document.getElementById('fiori-order-status');
  const fioriCancelBtn   = document.getElementById('fiori-cancel-btn');
  const fioriSubmitBtn   = document.getElementById('fiori-submit-btn');

  let selectedFlowerId = '';
  let selectedFlowerProduct = '';
  let selectedFlowerPrice   = '';
  let selectedFlowerPriceLabel = '';

  function setFioriStatus(type, message) {
    if (!fioriOrderStatus) return;
    fioriOrderStatus.className = `form-status status-${type}`;
    fioriOrderStatus.style.display = 'block';
    fioriOrderStatus.textContent = message;
  }

  function formatApiErrorDetail(detail) {
    if (!detail) return '';
    if (typeof detail === 'string') return detail;
    if (Array.isArray(detail)) return detail.map(formatApiErrorDetail).filter(Boolean).join(' ');
    if (typeof detail === 'object') {
      const field = detail.path || detail.param || detail.field || detail.property || '';
      const message = detail.msg || detail.message || detail.error || detail.detail || '';
      if (field && message) return `${field}: ${message}`;
      if (message) return String(message);
      return Object.entries(detail)
        .map(([key, value]) => `${key}: ${formatApiErrorDetail(value)}`)
        .filter(Boolean)
        .join(' ');
    }
    return String(detail);
  }

  function getFioriApiError(json) {
    return formatApiErrorDetail(json?.message)
      || formatApiErrorDetail(json?.error)
      || formatApiErrorDetail(json?.data?.message)
      || formatApiErrorDetail(json?.errors)
      || formatApiErrorDetail(json?.data?.errors)
      || 'Non siamo riusciti a registrare l\'ordine.';
  }

  function hideFioriStatus() {
    if (!fioriOrderStatus) return;
    fioriOrderStatus.style.display = 'none';
    fioriOrderStatus.textContent = '';
  }

  function parseAmount(value) {
    const amount = Number(String(value || '').replace(',', '.'));
    return Number.isFinite(amount) ? amount : 0;
  }

  function showFioriForm(button) {
    selectedFlowerId = button.dataset.productId || '';
    selectedFlowerProduct = button.dataset.product || '';
    selectedFlowerPrice = button.dataset.price || '';
    selectedFlowerPriceLabel = button.dataset.priceLabel || selectedFlowerPrice;

    // Product header
    const nameEl  = document.getElementById('fiori-inline-product-name');
    const priceEl = document.getElementById('fiori-inline-product-price');
    if (nameEl)  nameEl.textContent  = selectedFlowerProduct;
    if (priceEl) priceEl.textContent = `${selectedFlowerPriceLabel} IVA inclusa`;

    const fioreIdInput = document.getElementById('fiori-fiore-id');
    const fioreNameInput = document.getElementById('fiori-fiore-name');
    if (fioreIdInput) fioreIdInput.value = selectedFlowerId;
    if (fioreNameInput) fioreNameInput.value = selectedFlowerProduct;

    // Auto-fill defunto field
    const defuntoInput = document.getElementById('fiori-defunto');
    if (defuntoInput) defuntoInput.value = nomeDefuntoCompleto || '';

    // Reset form fields (except defunto)
    const mittente = document.getElementById('fiori-mittente');
    const nastro   = document.getElementById('fiori-nastro');
    const telefono = document.getElementById('fiori-telefono');
    const email    = document.getElementById('fiori-email');
    const note     = document.getElementById('fiori-note');
    const privacy  = document.getElementById('fiori-privacy');
    if (mittente)  mittente.value  = '';
    if (nastro)    nastro.value    = '';
    if (telefono)  telefono.value  = '';
    if (email)     email.value     = '';
    if (note)      note.value      = '';
    if (privacy)   privacy.checked = false;
    hideFioriStatus();

    // Show form and scroll to it
    if (fioriFormWrap) {
      fioriFormWrap.style.display = 'block';
      setTimeout(() => fioriFormWrap.scrollIntoView({ behavior: 'smooth', block: 'start' }), 60);
    }

    // Highlight selected card
    document.querySelectorAll('.fiori-card').forEach(card => {
      card.classList.toggle('fiori-card-selected', card.dataset.productId === selectedFlowerId);
    });
  }

  function hideFioriForm() {
    if (fioriFormWrap) fioriFormWrap.style.display = 'none';
    document.querySelectorAll('.fiori-card').forEach(c => c.classList.remove('fiori-card-selected'));
    hideFioriStatus();
  }

  // "Scegli" buttons
  document.querySelectorAll('.fiori-order-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      showFioriForm(btn);
    });
  });

  // Cancel button
  fioriCancelBtn?.addEventListener('click', hideFioriForm);

  // Form submit to Cas-Per
  fioriOrderForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!fioriSubmitBtn) return;

    {
      const privacyOk = document.getElementById('fiori-privacy')?.checked ?? false;
      if (!privacyOk) {
        setFioriStatus('error', 'È necessario accettare l\'informativa sulla privacy.');
        return;
      }

      const mittente = document.getElementById('fiori-mittente')?.value.trim() || '';
      const defunto = document.getElementById('fiori-defunto')?.value.trim() || '';
      const nastro = document.getElementById('fiori-nastro')?.value.trim() || '';
      const telefono = document.getElementById('fiori-telefono')?.value.trim() || '';
      const email = document.getElementById('fiori-email')?.value.trim() || '';
      const note = document.getElementById('fiori-note')?.value.trim() || '';

      if (!selectedFlowerId) {
        setFioriStatus('error', 'Seleziona una composizione floreale.');
        return;
      }

      const selectedFlowerNumericId = Number(selectedFlowerId);
      const selectedFlowerAmount = parseAmount(selectedFlowerPrice);

      if (!Number.isFinite(selectedFlowerNumericId) || selectedFlowerAmount <= 0) {
        setFioriStatus('error', 'La composizione selezionata non e disponibile. Ricarica la pagina e riprova.');
        return;
      }

      if (!mittente || !telefono || !email) {
        setFioriStatus('error', 'Nome, telefono ed email sono obbligatori.');
        return;
      }

      const originalText = fioriSubmitBtn.innerHTML;
      fioriSubmitBtn.disabled = true;
      fioriSubmitBtn.innerHTML = '<span class="spinner-inline"></span> Invio ordine...';
      setFioriStatus('info', 'Stiamo inviando il tuo ordine alla fioreria.');

      const payload = {
        fiore_id: selectedFlowerNumericId,
        id_fiore: selectedFlowerNumericId,
        prodotto_id: selectedFlowerNumericId,
        fiore_nome: selectedFlowerProduct,
        prodotto: selectedFlowerProduct,
        importo: selectedFlowerAmount,
        prezzo: selectedFlowerAmount,
        prezzo_label: selectedFlowerPriceLabel,
        quantita: 1,
        slug,
        annuncio_id: annuncioId,
        id_annuncio: annuncioId,
        annuncio_slug: slug,
        nominativo: mittente,
        nome: mittente,
        mittente,
        mittente_nome: mittente,
        telefono,
        mittente_telefono: telefono,
        email,
        mail: email,
        mittente_email: email,
        defunto,
        nome_defunto: defuntoNome,
        cognome_defunto: defuntoCognome,
        nastro,
        testo_nastro: nastro,
        messaggio_nastro: nastro,
        biglietto: nastro,
        note,
        messaggio: note,
        luogo_consegna: 'Presso il luogo delle esequie',
        metodo_pagamento: 'consegna',
        pagamento: 'consegna',
        privacy: true,
        accetta_privacy: true,
        provenienza: 1
      };

      try {
        const response = await fetch('/casper-api/public/v1/fiori-ordini', {
          method: 'POST',
          headers: {
            'X-API-Key': apiKey,
            'Accept': 'application/json',
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const json = await response.json().catch(() => ({}));
        if (!response.ok || json.success === false) {
          throw new Error(getFioriApiError(json));
        }

        const checkoutUrl = json.data?.checkout_url || json.data?.payment_url || json.checkout_url || json.payment_url;

        setFioriStatus('success', 'Ordine ricevuto. Il nostro staff ti contatterà per confermare consegna e pagamento.');
        fioriOrderForm.reset();
        const defuntoInput = document.getElementById('fiori-defunto');
        if (defuntoInput) defuntoInput.value = nomeDefuntoCompleto || '';

        if (checkoutUrl) {
          window.location.href = checkoutUrl;
        }
      } catch (err) {
        setFioriStatus('error', err.message || 'Si è verificato un errore durante l\'invio dell\'ordine. Riprova più tardi.');
      } finally {
        fioriSubmitBtn.disabled = false;
        fioriSubmitBtn.innerHTML = originalText;
      }

      return;
    }

  });
</script>

