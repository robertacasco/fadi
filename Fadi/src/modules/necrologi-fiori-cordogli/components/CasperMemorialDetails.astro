---
import type { AnnuncioData } from '../types';
import { getFotoUrl, formatMorte, formatNascita, formatCerimoniaOra, formatCerimoniaData } from '../utils/formatters';

interface Props {
  item: AnnuncioData;
}

const { item } = Astro.props;

const defunto  = item.defunto  || {};
const annuncio = item.annuncio || {};
const funerale = item.funerale || {};
const rosario  = item.rosario  || {};
const sepoltura = item.sepoltura || {};
const luogoRiposo = item.luogo_riposo || {};
const streaming = item.streaming || {};
const nomeCompleto = item.nominativo || `${defunto.nome || ''} ${defunto.cognome || ''}`.trim();
const haFoto   = !!defunto.foto_url;

const fotoSrc = getFotoUrl(defunto, item.updated_at);
const dataMorteIta = formatMorte(defunto.data_morte);
const dataNascitaIta = formatNascita(defunto.data_nascita);
const familySlug = item.slug || '';
const familyAreaUrl = familySlug
  ? `https://admin.annuncifunebri.it/famiglia/${encodeURIComponent(familySlug)}`
  : '';
const memorialShareUrl = familySlug
  ? `https://fadi-lake.vercel.app/necrologi/${encodeURIComponent(familySlug)}/`
  : 'https://fadi-lake.vercel.app/necrologi/';
const memorialShareText = `In memoria di ${nomeCompleto}`;
const encodedShareUrl = encodeURIComponent(memorialShareUrl);
const encodedShareText = encodeURIComponent(memorialShareText);
---

<!-- Memorial Header Section -->
<section class="memorial-header-section">
  <div class="container header-grid">
    <!-- Left side: elegant photo representation -->
    <div class="memorial-photo-wrapper" style="display: flex; flex-direction: column; gap: 1.5rem; align-items: center; width: 100%; max-width: 320px; margin: 0 auto;">
      <div class="memorial-frame" style="width: 100%;">
        {haFoto ? (
          <img 
            src={fotoSrc}
            alt={`Foto di ${nomeCompleto}`}
            class="memorial-image"
          />
        ) : (
          <div class="memorial-image-placeholder">
            <div class="placeholder-cross-lg">✝</div>
          </div>
        )}
        <div class="frame-gold-border"></div>
      </div>

      <div class="action-buttons-group-vertical" style="display: flex; flex-direction: column; gap: 0.75rem; width: 100%;">
        <button type="button" id="hero-btn-cordoglio" class="btn btn-gold" aria-controls="cordoglio-modal" aria-haspopup="dialog" style="width: 100%; justify-content: center; padding: 0.9rem 0;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right: 0.35rem;">
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
          Invia Cordoglio
        </button>
        <button type="button" id="hero-btn-photo" class="btn btn-outline-gold" aria-controls="cordoglio-modal" aria-haspopup="dialog" style="width: 100%; justify-content: center; padding: 0.9rem 0;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right: 0.35rem;">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
          Invia una Foto
        </button>
        <button type="button" id="hero-btn-fiori" class="btn btn-outline-gold" aria-controls="fiori-modal" aria-haspopup="dialog" style="width: 100%; justify-content: center; padding: 0.9rem 0;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right: 0.35rem;">
            <circle cx="12" cy="12" r="2.5"/>
            <path d="M12 2a2.5 2.5 0 0 1 2.5 2.5c0 1.5-2.5 4-2.5 4s-2.5-2.5-2.5-4A2.5 2.5 0 0 1 12 2z"/>
            <path d="M22 12a2.5 2.5 0 0 1-2.5 2.5c-1.5 0-4-2.5-4-2.5s2.5-2.5 4-2.5A2.5 2.5 0 0 1 22 12z"/>
            <path d="M12 22a2.5 2.5 0 0 1-2.5-2.5c0-1.5 2.5-4 2.5-4s2.5 2.5 2.5 4A2.5 2.5 0 0 1 12 22z"/>
            <path d="M2 12a2.5 2.5 0 0 1 2.5-2.5c1.5 0 4 2.5 4 2.5s-2.5 2.5-4 2.5A2.5 2.5 0 0 1 2 12z"/>
            <path d="M19.07 4.93a2.5 2.5 0 0 1 0 3.54c-1.06 1.06-4.24.7-4.24.7s-.36-3.18.7-4.24a2.5 2.5 0 0 1 3.54 0z"/>
            <path d="M4.93 4.93a2.5 2.5 0 0 1 3.54 0c1.06 1.06.7 4.24.7 4.24s-3.18.36-4.24-.7a2.5 2.5 0 0 1 0-3.54z"/>
            <path d="M4.93 19.07a2.5 2.5 0 0 1 0-3.54c1.06-1.06 4.24-.7 4.24-.7s.36 3.18-.7 4.24a2.5 2.5 0 0 1-3.54 0z"/>
            <path d="M19.07 19.07a2.5 2.5 0 0 1-3.54 0c-1.06-1.06-.7-4.24-.7-4.24s3.18-.36 4.24.7a2.5 2.5 0 0 1 0 3.54z"/>
          </svg>
          Invia dei Fiori
        </button>
      </div>
    </div>

    <!-- Right side: details and text -->
    <div class="memorial-primary-info">
      <div class="emblem" aria-hidden="true">✝</div>
      <span class="annuncio-label">In Memoria di</span>
      <h1 class="deceased-name">{nomeCompleto}</h1>
      
      <div class="dates-eta">
        {dataMorteIta && (
          <div class="info-tag">
            <span class="tag-title">Deceduto il:</span>
            <span class="tag-val">{dataMorteIta}</span>
          </div>
        )}
        {dataNascitaIta && (
          <div class="info-tag">
            <span class="tag-title">Nato il:</span>
            <span class="tag-val">{dataNascitaIta}</span>
          </div>
        )}
        {(defunto as any).eta_visibile && (defunto as any).eta && (
          <div class="info-tag">
            <span class="tag-title">Età:</span>
            <span class="tag-val">{(defunto as any).eta} Anni</span>
          </div>
        )}
      </div>

      {annuncio.citazione && (
        <blockquote class="deceased-quote">
          <p>“{annuncio.citazione}”</p>
        </blockquote>
      )}

      {annuncio.epigrafe_url && (
        <div class="manifesto-preview-wrapper" style="cursor: pointer; width: 100%; max-width: 270px; margin-bottom: 0.85rem;">
          <div class="manifesto-thumbnail-card" id="open-manifesto-btn" style="position: relative; border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; background: #ffffff; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: all var(--transition);">
            <img src={annuncio.epigrafe_url} alt={`Manifesto di ${nomeCompleto}`} style="width: 100%; height: auto; display: block;" />
            <div class="manifesto-overlay" style="position: absolute; inset: 0; background: rgba(44, 38, 32, 0.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity var(--transition);">
              <span style="color: #ffffff; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #ffffff; padding: 0.4rem 0.8rem; border-radius: 4px; background: rgba(0,0,0,0.2);">Ingrandisci</span>
            </div>
          </div>
          <div class="manifesto-share-row">
            <span class="manifesto-share-label">Manifesto Funebre</span>
            <div class="manifesto-share-actions" aria-label="Condividi annuncio">
              <a
                href={`https://wa.me/?text=${encodedShareText}%20${encodedShareUrl}`}
                target="_blank"
                rel="noopener noreferrer"
                class="manifesto-share-btn"
                aria-label="Condividi su WhatsApp"
                title="WhatsApp"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.34 4.95L2 22l5.28-1.39a9.88 9.88 0 0 0 4.76 1.22h.01c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2Zm5.77 14.18c-.24.68-1.41 1.3-1.97 1.34-.5.04-1.14.06-1.84-.11-.42-.1-.96-.31-1.65-.61-2.9-1.25-4.79-4.16-4.94-4.35-.14-.19-1.18-1.57-1.18-3 0-1.43.75-2.13 1.02-2.42.27-.29.59-.36.79-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.58.84 2 .91 2.14.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.75 1.24 1.62 2.01 1.11.99 2.04 1.3 2.33 1.45.29.15.46.12.63-.07.17-.19.72-.84.92-1.13.19-.29.39-.24.66-.15.27.1 1.72.81 2.01.96.29.15.48.22.56.34.07.12.07.7-.17 1.38Z"/>
                </svg>
              </a>
              <a
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodedShareUrl}`}
                target="_blank"
                rel="noopener noreferrer"
                class="manifesto-share-btn"
                aria-label="Condividi su Facebook"
                title="Facebook"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M14 8.2V6.6c0-.8.2-1.3 1.3-1.3h1.5V2.2c-.7-.1-1.5-.2-2.3-.2-2.8 0-4.7 1.7-4.7 4.8v1.4H7v3.4h2.8V22h3.5V11.6h2.9l.5-3.4H14Z"/>
                </svg>
              </a>
              <a
                href={`mailto:?subject=${encodedShareText}&body=${encodedShareText}%0A${encodedShareUrl}`}
                class="manifesto-share-btn"
                aria-label="Condividi via email"
                title="Email"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2"/>
                  <path d="m3 7 9 6 9-6"/>
                </svg>
              </a>
              <button
                type="button"
                class="manifesto-share-btn"
                data-copy-share-url={memorialShareUrl}
                aria-label="Copia link annuncio"
                title="Copia link"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M10 13a5 5 0 0 0 7.07 0l2.12-2.12a5 5 0 0 0-7.07-7.07L11 4.93"/>
                  <path d="M14 11a5 5 0 0 0-7.07 0L4.81 13.12a5 5 0 0 0 7.07 7.07L13 19.07"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      )}

      {familyAreaUrl && (
        <div class:list={['family-area-access-wrapper', { 'family-area-access-wrapper--solo': !annuncio.epigrafe_url }]}>
          <button
            type="button"
            id="open-family-area-modal"
            class="family-area-inline-btn"
            aria-haspopup="dialog"
            aria-controls="family-area-modal"
          >
            Area famiglia
          </button>
        </div>
      )}
    </div>
  </div>
</section>

<!-- Ceremony Details Grid -->
<section class="section ceremonies-section">
  <div class="container">
    <div class="text-center section-header">
      <span class="section-label">Cerimonie</span>
      <h2 class="section-title">Orari e luoghi del commiato</h2>
      <div class="divider mx-auto"></div>
    </div>

    <div class="ceremonies-grid">
      <!-- ROSARIO CARD -->
      {rosario.luogo || rosario.data_ora ? (
        <div class="ceremony-detail-card card">
          <div class="ceremony-header">
            <span class="ceremony-card-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="9" r="6" stroke-dasharray="0 4" />
                <path d="M12 15v6M9 18h6" />
              </svg>
            </span>
            <h3>Santo rosario</h3>
          </div>
          <div class="ceremony-body">
            {rosario.data_ora && (
              <div class="time-block">
                <span class="time-date">{formatCerimoniaData(rosario.data_ora)}</span>
                <span class="time-hours">{formatCerimoniaOra(rosario.data_ora)}</span>
              </div>
            )}
            <div class="address-block">
              <span class="place-name">{rosario.luogo || 'Presso la Chiesa'}</span>
              {rosario.indirizzo && <span class="place-address">{rosario.indirizzo}</span>}
            </div>
          </div>
          {rosario.link_maps && (
            <a href={(rosario as any).link_maps} target="_blank" rel="noopener noreferrer" class="maps-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Indicazioni stradali
            </a>
          )}
        </div>
      ) : null}

      <!-- FUNERALE CARD -->
      {funerale.luogo || funerale.data_ora ? (
        <div class="ceremony-detail-card card card-highlighted">
          <div class="ceremony-header">
            <span class="ceremony-card-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M8 8h8" />
              </svg>
            </span>
            <h3>Cerimonia funebre</h3>
          </div>
          <div class="ceremony-body">
            {funerale.data_ora && (
              <div class="time-block">
                <span class="time-date">{formatCerimoniaData(funerale.data_ora)}</span>
                <span class="time-hours">{formatCerimoniaOra(funerale.data_ora)}</span>
              </div>
            )}
            <div class="address-block">
              <span class="place-name">{funerale.luogo || 'Chiesa Parrocchiale'}</span>
              {funerale.indirizzo && <span class="place-address">{funerale.indirizzo}</span>}
            </div>
          </div>
          {funerale.link_maps && (
            <a href={(funerale as any).link_maps} target="_blank" rel="noopener noreferrer" class="maps-link highlighted-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Indicazioni stradali
            </a>
          )}
        </div>
      ) : null}

      <!-- LUOGO DI RIPOSO CARD -->
      {luogoRiposo.luogo || luogoRiposo.indirizzo ? (
        <div class="ceremony-detail-card card">
          <div class="ceremony-header">
            <span class="ceremony-card-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 21h12M12 18v3" />
                <rect x="10" y="11" width="4" height="7" rx="0.5" />
                <path d="M12 11V8" />
                <path d="M12 3c-0.8 1.5-0.8 2.5 0 4 0.8-1.5 0.8-2.5 0-4z" fill="currentColor" stroke="none" />
              </svg>
            </span>
            <h3>Camera ardente</h3>
          </div>
          <div class="ceremony-body">
            <div class="address-block" style="margin-top: 1rem;">
              <span class="place-name">{luogoRiposo.luogo}</span>
              {luogoRiposo.indirizzo && <span class="place-address">{luogoRiposo.indirizzo}</span>}
            </div>
          </div>
          {luogoRiposo.link_maps && (
            <a href={(luogoRiposo as any).link_maps} target="_blank" rel="noopener noreferrer" class="maps-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Indicazioni stradali
            </a>
          )}
        </div>
      ) : null}

      <!-- SEPOLTURA CARD -->
      {sepoltura.luogo || sepoltura.indirizzo ? (
        <div class="ceremony-detail-card card">
          <div class="ceremony-header">
            <span class="ceremony-card-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 20V10a6 6 0 0 1 12 0v10" />
                <path d="M3 20h18" />
                <path d="M12 8v6M10 10h4" />
              </svg>
            </span>
            <h3>Sepoltura</h3>
          </div>
          <div class="ceremony-body">
            <div class="address-block" style="margin-top: 1rem;">
              <span class="place-name">{sepoltura.luogo || 'Cimitero Comunale'}</span>
              {sepoltura.indirizzo && <span class="place-address">{sepoltura.indirizzo}</span>}
            </div>
          </div>
          {sepoltura.link_maps && (
            <a href={(sepoltura as any).link_maps} target="_blank" rel="noopener noreferrer" class="maps-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Indicazioni stradali
            </a>
          )}
        </div>
      ) : null}
    </div>

    <!-- Live Stream Streaming Option -->
    {streaming.url_video && (
      <div class="streaming-block text-center">
        <div class="streaming-inner card">
          <span class="live-dot-pulse"></span>
          <h3>Diretta streaming della cerimonia</h3>
          <p>Per coloro che non possono partecipare fisicamente, è possibile seguire la cerimonia funebre in diretta streaming online.</p>
          <a href={streaming.url_video} target="_blank" rel="noopener noreferrer" class="btn btn-gold streaming-btn">
            ▶ Segui la diretta streaming
          </a>
        </div>
      </div>
    )}
  </div>
</section>

{annuncio.epigrafe_url && (
  <div id="manifesto-modal" class="manifesto-modal-overlay">
    <div class="manifesto-modal-content">
      <button id="close-manifesto-btn" class="close-manifesto-btn" type="button">
        &times;
      </button>
      <img src={annuncio.epigrafe_url} alt={`Manifesto Funebre di ${nomeCompleto}`} />
      <div class="manifesto-modal-caption">
        Manifesto Funebre di {nomeCompleto}
      </div>
    </div>
  </div>
)}

{familyAreaUrl && (
  <div id="family-area-modal" class="family-area-modal-overlay" aria-hidden="true">
    <div class="family-area-modal-content" role="dialog" aria-modal="true" aria-labelledby="family-area-modal-title">
      <button id="close-family-area-modal" class="family-area-modal-close" type="button" aria-label="Chiudi area famiglia">
        &times;
      </button>
      <span class="family-area-modal-kicker">Accesso riservato</span>
      <h2 id="family-area-modal-title">Area famiglia</h2>
      <p>Accesso per la famiglia di {nomeCompleto}.</p>
      <form method="post" action={`${familyAreaUrl}/access`} class="family-area-pin-form">
        <label for="family-area-pin">PIN ricevuto</label>
        <input
          id="family-area-pin"
          name="pin"
          type="password"
          inputmode="numeric"
          autocomplete="one-time-code"
          placeholder="Inserisci il PIN"
          required
        />
        <button type="submit" class="btn btn-gold family-area-submit">Accedi</button>
      </form>
    </div>
  </div>
)}

<style>
  .family-area-inline-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-top: 0.9rem;
    padding: 0.62rem 0.8rem;
    border: 1px solid rgba(184, 150, 110, 0.34);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.42);
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .family-area-access-wrapper {
    width: 100%;
    max-width: 270px;
    margin-bottom: 2rem;
  }

  .family-area-access-wrapper--solo {
    margin-top: 1.35rem;
  }

  .family-area-inline-btn:hover {
    color: var(--gold);
    border-color: var(--gold);
    background: var(--gold-dim);
  }

  .family-area-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100000;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    background: rgba(44, 38, 32, 0.56);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .family-area-modal-overlay.active {
    display: flex;
  }

  .family-area-modal-content {
    position: relative;
    width: min(100%, 420px);
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: 0 24px 70px rgba(44, 38, 32, 0.24);
  }

  .family-area-modal-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: #fff;
    color: var(--text-muted);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }

  .family-area-modal-kicker {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .family-area-modal-content h2 {
    margin-bottom: 0.4rem;
    font-size: 1.55rem;
  }

  .family-area-modal-content p {
    color: var(--text-muted);
    margin-bottom: 1.1rem;
    line-height: 1.6;
  }

  .family-area-pin-form {
    display: grid;
    gap: 0.75rem;
  }

  .family-area-pin-form label {
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .family-area-pin-form input {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.85rem 1rem;
    outline: none;
  }

  .family-area-pin-form input:focus {
    border-color: var(--gold);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(184, 150, 110, 0.12);
  }

  .family-area-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.35rem;
  }

  @media (max-width: 900px) {
    .family-area-inline-btn {
      max-width: 270px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>

<script>
  const openFamilyArea = document.getElementById('open-family-area-modal');
  const familyAreaModal = document.getElementById('family-area-modal');
  const closeFamilyArea = document.getElementById('close-family-area-modal');
  const familyPinInput = document.getElementById('family-area-pin');

  function closeFamilyAreaModal() {
    familyAreaModal?.classList.remove('active');
    familyAreaModal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openFamilyArea?.addEventListener('click', () => {
    familyAreaModal?.classList.add('active');
    familyAreaModal?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => familyPinInput?.focus(), 30);
  });

  closeFamilyArea?.addEventListener('click', closeFamilyAreaModal);
  familyAreaModal?.addEventListener('click', (event) => {
    if (event.target === familyAreaModal) {
      closeFamilyAreaModal();
    }
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && familyAreaModal?.classList.contains('active')) {
      closeFamilyAreaModal();
    }
  });
</script>
