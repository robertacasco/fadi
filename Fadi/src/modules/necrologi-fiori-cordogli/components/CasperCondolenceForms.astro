---
import type { AnnuncioData, FioreData } from '../types';
import { isPublicOnlinePaymentEnabled } from '../payments/config';

interface Props {
  item: AnnuncioData;
  fiori?: FioreData[];
}

const { item, fiori = [] } = Astro.props;
const onlinePaymentEnabled = isPublicOnlinePaymentEnabled();
const sourceFiori = fiori.filter((fiore) => fiore.attivo !== false);

const localFioriCatalog = [
  {
    id: 'ciotola-fiori-stagione',
    nome: 'Ciotola di fiori di stagione',
    descrizione: 'Ideale per un funerale. Un gesto più sentito.',
    prezzo: 40,
    prezzoPrefix: 'A partire da ',
    immagine: '/fiori/ciotola-fiori-stagione.png',
    aliases: ['ciotola', 'composizione floreale']
  },
  {
    id: 'mazzo-di-fiori',
    nome: 'Mazzo di fiori',
    descrizione: 'Classico, ideale per funerali. Un semplice ma gradito pensiero.',
    prezzo: 10,
    immagine: '/fiori/mazzo-di-fiori.png',
    aliases: ['mazzo di fiori']
  },
  {
    id: 'bouquet',
    nome: 'Bouquet',
    descrizione: 'Composizione floreale elegante e raccolta. Un pensiero sobrio per esprimere vicinanza.',
    prezzo: 30,
    immagine: '/fiori/bouquet.png',
    aliases: ['mazzo di fiori', 'bouquet']
  },
  {
    id: 'corona-di-fiori',
    nome: 'Corona di fiori',
    descrizione: 'Composizione funebre circolare. Un omaggio importante e sentito.',
    prezzo: 150,
    immagine: '/fiori/corona.png',
    aliases: ['corona', 'corona di fiori']
  },
  {
    id: 'cuscino',
    nome: 'Cuscino',
    descrizione: 'Composizione compatta e raffinata. Ideale per un pensiero di affetto e vicinanza.',
    prezzo: 80,
    immagine: '/fiori/cuscino.png',
    aliases: ['cuscino', 'cuscino di fiori']
  },
  {
    id: 'cuore',
    nome: 'Cuore',
    descrizione: 'Composizione a forma di cuore. Un omaggio sentito per esprimere affetto e vicinanza.',
    prezzo: 70,
    immagine: '/fiori/cuore.png',
    aliases: ['cuore', 'cuscino a forma di cuore']
  },
  {
    id: 'copri-bara',
    nome: 'Copri bara',
    descrizione: 'Composizione floreale per feretro. Un omaggio elegante, importante e rispettoso.',
    prezzo: 400,
    immagine: '/fiori/copri-bara.png',
    aliases: ['copri bara', 'copribara']
  }
];

function normalizeFioreName(value: string): string {
  return value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, ' ')
    .trim();
}

function getFioreName(fiore: FioreData): string {
  return fiore.nome || fiore.denominazione || fiore.titolo || fiore.name || `Composizione ${fiore.id}`;
}

function getFioreDescription(fiore: FioreData): string {
  return fiore.descrizione || fiore.descrizione_breve || fiore.description || '';
}

function getFioreAmount(fiore: FioreData): number | null {
  const raw = fiore.importo ?? fiore.prezzo_ivato ?? fiore.prezzo ?? fiore.price ?? fiore.amount;
  if (raw === undefined || raw === null || raw === '') return null;
  const value = Number(String(raw).replace(',', '.'));
  return Number.isFinite(value) ? value : null;
}

function findSourceFiore(aliases: string[], prezzo: number): FioreData | undefined {
  const normalizedAliases = aliases.map(normalizeFioreName);
  return sourceFiori.find((fiore) => {
    const name = normalizeFioreName(getFioreName(fiore));
    const amount = getFioreAmount(fiore);
    const nameMatches = normalizedAliases.some((alias) => name === alias || name.includes(alias));
    return nameMatches && amount === prezzo;
  });
}

const matchedLocalFiori: FioreData[] = localFioriCatalog.flatMap(({ aliases, prezzoPrefix, ...fiore }) => {
  const sourceFiore = findSourceFiore(aliases, fiore.prezzo);
  if (!sourceFiore) return [];

  return [{
    ...sourceFiore,
    nome: fiore.nome,
    descrizione: fiore.descrizione,
    immagine: fiore.immagine,
    prezzoPrefix,
  }];
});

const activeFiori = matchedLocalFiori;

function getFioreImage(fiore: FioreData): string {
  return fiore.immagine_url || fiore.immagine || fiore.foto_url || fiore.image_url || fiore.url_immagine || '/fiori/composizione.png';
}

function getFiorePriceValue(fiore: FioreData): string {
  const raw = fiore.importo ?? fiore.prezzo_ivato ?? fiore.prezzo ?? fiore.price ?? fiore.amount ?? '';
  return String(raw);
}

function formatFiorePrice(fiore: FioreData): string {
  const amount = getFioreAmount(fiore);
  if (!Number.isFinite(amount)) return getFiorePriceValue(fiore);

  const price = new Intl.NumberFormat('it-IT', {
    style: 'currency',
    currency: 'EUR'
  }).format(amount || 0);

  return `${fiore.prezzoPrefix || ''}${price}`;
}
---

<!-- Interactive Forms Modal -->
<div id="cordoglio-modal" class="memorial-action-modal-overlay" aria-hidden="true">
  <div class="memorial-action-modal-content memorial-action-modal-content--cordoglio" role="dialog" aria-modal="true" aria-labelledby="cordoglio-modal-title" tabindex="-1">
    <button type="button" class="memorial-action-modal-close" data-modal-close aria-label="Chiudi finestra">&times;</button>
    <section class="section interactive-memorial-section" id="interactive-area">
      <div class="container interactive-grid">
    <!-- CONDOLENCE FORM COLUMN -->
    <div class="condolence-column" id="cordoglio" style="width: 100%;">
      <div class="interactive-card card">
