---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'funerali',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>`,
    title: 'Funerali completi',
    desc: "Organizzazione integrale della cerimonia funebre, dalla comunicazione alla sepoltura, con assistenza completa alla famiglia in ogni fase.",
  },
  {
    id: 'personale',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>`,
    title: 'Personale qualificato',
    desc: "Team professionale e formato per accompagnare le famiglie con discrezione, competenza e rispetto nel momento più delicato.",
  },
  {
    id: 'trasporti',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="m16 8 4 1 3 3v4h-2M1 16h15"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
    title: 'Trasporti nazionali e internazionali',
    desc: "Servizio di trasporto funebre su tutto il territorio italiano e internazionale, con automezzi propri e personale specializzato.",
  },
  {
    id: 'portafiori',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22V12M12 12C12 12 8 10 8 6a4 4 0 0 1 8 0c0 4-4 6-4 6z"/><path d="M12 12c0 0-4-2-6-5.5A4 4 0 0 1 12 7"/></svg>`,
    title: 'Auto porta fiori',
    desc: "Veicolo dedicato al trasporto dei fiori e delle corone durante il corteo funebre, con cura e rispetto per i tributi floreali.",
  },
  {
    id: 'prelapidi',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a7 7 0 0 1 7 7v3H5V9a7 7 0 0 1 7-7z"/><rect x="5" y="12" width="14" height="10" rx="1"/></svg>`,
    title: 'Prelapidi',
    desc: "Realizzazione e fornitura di lapidi commemorative, con personalizzazione secondo le esigenze e i desideri della famiglia.",
  },
  {
    id: 'casse',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="17"/><line x1="9.5" y1="14.5" x2="14.5" y2="14.5"/></svg>`,
    title: 'Casse funebri',
    desc: "Ampia selezione di casse funebri in diversi materiali e finiture, con possibilità di personalizzazione per ogni esigenza.",
  },
  {
    id: 'vestizioni',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>`,
    title: 'Vestizioni',
    desc: "Servizio di vestizione del defunto eseguito con cura, rispetto e professionalità dal nostro personale qualificato.",
  },
  {
    id: 'religiosi',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="2" x2="12" y2="22"/><line x1="7" y1="7" x2="17" y2="7"/></svg>`,
    title: 'Servizi religiosi',
    desc: "Coordinamento con le autorità religiose per la celebrazione della messa funebre e di ogni altra cerimonia religiosa.",
  },
  {
    id: 'fiori-corone',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Fiori e corone',
    desc: "Selezione e fornitura di fiori freschi, corone e composizioni floreali per la cerimonia funebre, tramite la nostra fioreria.",
  },
  {
    id: 'pratiche',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    title: 'Disbrigo pratiche burocratiche',
    desc: "Assistenza completa per tutte le pratiche amministrative e burocratiche necessarie: denuncia di decesso, comunicazioni, documentazione.",
  },
];
---

<Layout
  title="Servizi — Onoranze Funebri FADI | Dasà (VV)"
  description="Funerali completi, trasporti nazionali e internazionali, vestizioni, pratiche burocratiche, fioreria e molto altro. Onoranze Funebri FADI dal 1991. Tel. 0963 353321."
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label">30 anni di esperienza al tuo servizio</p>
      <h1 class="page-hero-title">I nostri servizi</h1>
      <div class="divider"></div>
      <p class="page-hero-sub">
        Dall'organizzazione del funerale al disbrigo delle pratiche burocratiche, siamo al tuo fianco
        in ogni fase con professionalità, discrezione e rispetto.
      </p>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section class="section" id="lista-servizi">
    <div class="container">
      <div class="services-grid">
        {services.map(s => (
          <div class="srv-card" id={`servizio-${s.id}`}>
            <div class="srv-icon" aria-hidden="true" set:html={s.icon} />
            <div class="srv-body">
              <h2 class="srv-title">{s.title}</h2>
              <p class="srv-desc">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2>Contattaci, saremo al tuo fianco con delicatezza e professionalità</h2>
        <p>Disponibili 24 ore su 24, anche nei festivi.</p>
      </div>
      <div class="cta-actions">
        <a href="tel:+390963353321" class="btn btn-gold" id="servizi-cta-tel">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.58a1 1 0 0 1-.24 1.01l-2.21 2.2z"/></svg>
          Chiama ora
        </a>
        <a href="https://wa.me/+39328353321" target="_blank" rel="noopener noreferrer" class="btn btn-outline" id="servizi-cta-contatti">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.34 4.95L2 22l5.28-1.39a9.88 9.88 0 0 0 4.76 1.22h.01c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2Zm5.77 14.18c-.24.68-1.41 1.3-1.97 1.34-.5.04-1.14.06-1.84-.11-.42-.1-.96-.31-1.65-.61-2.9-1.25-4.79-4.16-4.94-4.35-.14-.19-1.18-1.57-1.18-3 0-1.43.75-2.13 1.02-2.42.27-.29.59-.36.79-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.58.84 2 .91 2.14.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.75 1.24 1.62 2.01 1.11.99 2.04 1.3 2.33 1.45.29.15.46.12.63-.07.17-.19.72-.84.92-1.13.19-.29.39-.24.66-.15.27.1 1.72.81 2.01.96.29.15.48.22.56.34.07.12.07.7-.17 1.38Z"/></svg>
          Scrivi un messaggio
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background-image: 
      linear-gradient(to bottom, rgba(20, 18, 16, 0.65) 0%, rgba(20, 18, 16, 0.92) 100%),
      url('../img/sfondi/servizi.jpg');
    background-size: cover;
    background-position: center;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .page-hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-top: 0.75rem;
    color: #ffffff; /* Bright white title */
  }
  .page-hero-sub {
    color: #e5e1db; /* Readable light warm-grey subtitle */
    font-size: 1.05rem;
    max-width: 580px;
    margin-top: 1rem;
    line-height: 1.75;
  }
  .page-hero .section-label {
    color: var(--gold-light) !important;
  }
  .page-hero .divider {
    background: var(--gold) !important;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .srv-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(44, 38, 32, 0.02);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .srv-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(184, 150, 110, 0.08);
  }
  .srv-icon {
    width: 48px;
    height: 48px;
    background: var(--gold-dim);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
  }
  .srv-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .srv-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
  .cta-strip {
    background: linear-gradient(135deg, rgba(184,150,110,0.1) 0%, rgba(184,150,110,0.03) 100%);
    border-top: 1px solid var(--border);
    padding: 3.5rem 0;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta-text h2 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .cta-text p { color: var(--text-muted); font-size: 0.92rem; }
  .cta-actions { display: flex; gap: 1rem; flex-shrink: 0; flex-wrap: wrap; }
  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; text-align: center; }
    .cta-actions { justify-content: center; }
  }
</style>
